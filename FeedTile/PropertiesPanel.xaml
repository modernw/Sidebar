<UserControl x:Class="WindowsModern.FeedTile.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.FeedTile"
             mc:Ignorable="d" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,10,10,10">
			<StackPanel>
				<GroupBox Name="FeedSourceGroup" Header="Feed Source" Padding="5,5,5,5">
					<StackPanel>
						<RadioButton Margin="0,5,0,5" Name="InputUseAll">All Source</RadioButton>
						<RadioButton Margin="0,5,0,5" Name="InputUseSelected">Selected Source</RadioButton>
						<ListBox Margin="15,5,0,5" MinHeight="50" Name="ListFeedSources" MaxHeight="150">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<CheckBox Margin="2,2,2,2" IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=IsSelected, Mode=TwoWay}"
										Content="{Binding Path}" ToolTip="{Binding Title}" />
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</StackPanel>
				</GroupBox>
				<TextBlock Margin="0,10,0,0" Name="LabelShowItemsCount">Show Items Count</TextBlock>
				<ComboBox Margin="0,5,0,5" Name="SelectShowItemsCount">
				</ComboBox>
				<CheckBox Margin="0,10,0,0" Name="InputAutoSize">Auto Size when Auto Size Mode</CheckBox>
				<TextBlock Margin="0,10,0,5" Name="LabelShowItemsWhenAutoSize">Show Items Count when Auto Size</TextBlock>
				<ComboBox Margin="0,5,0,5" Name="SelectShowItemsWhenAutoSize">
				</ComboBox>
			</StackPanel>
		</ScrollViewer>
    </Grid>
</UserControl>
