<UserControl x:Class="WindowsModern.FeedTile.FlyoutPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.FeedTile"
             mc:Ignorable="d" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             d:DesignHeight="300" d:DesignWidth="400">
	<Grid>
		<DockPanel Width="370">
			<Grid DockPanel.Dock="Top" Height="52">
				<Rectangle Style="{DynamicResource TileFeedFlyoutHeaderBackground}"></Rectangle>
				<TextBlock Name="FeedTitle" TextTrimming="CharacterEllipsis" Style="{DynamicResource TileFeedFlyoutHeaderTitle}"></TextBlock>
				<Button Name="ButtonBack" Focusable="False" HorizontalAlignment="Left" Style="{DynamicResource TileFeedFlyoutSwitchButton}" Click="ButtonBack_Click">3</Button>
				<Button Name="ButtonNext" Focusable="False" HorizontalAlignment="Right" Style="{DynamicResource TileFeedFlyoutSwitchButton}" Click="ButtonNext_Click">4</Button>
			</Grid>
			<Line DockPanel.Dock="Top" Style="{DynamicResource TileFeedFlyoutLine}"></Line>
			<ScrollViewer Style="{DynamicResource TileFeedFlyoutContentPart}" VerticalScrollBarVisibility="Auto">
				<WrapPanel Style="{DynamicResource TileFeedFlyoutContentContainer}" Name="FeedItemList">
					
				</WrapPanel>
			</ScrollViewer>
		</DockPanel>
    </Grid>
</UserControl>
