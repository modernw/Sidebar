<Window x:Class="Sidebar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sidebar"
		xmlns:snt="clr-namespace:Sidebar;assembly=Native"
        mc:Ignorable="d" ResizeMode="NoResize" Opacity="1" ShowInTaskbar="False"
        Title="MainWindow" Height="600" Width="150" Background="Transparent" AllowsTransparency="True" WindowStyle="None" SizeChanged="Window_SizeChanged" HorizontalAlignment="Stretch" VerticalAlignment="Top" Unloaded="Window_Unloaded" Loaded="Window_Loaded" ContentRendered="Window_ContentRendered" SourceInitialized="Window_SourceInitialized" Closed="Window_Closed" MouseMove="Window_MouseMove" MouseDoubleClick="Window_MouseDoubleClick">
	<Window.Resources>
		<local:DirectionToScaleXConverter x:Key="DirectionToScaleX"/>
		<DoubleAnimation x:Key="LoadAnimOffset"
                     BeginTime="0:0:0.05"
                     Duration="0:0:0.25"
                     To="0"
                     Storyboard.TargetName="OpacityMaskGradStop"
                     Storyboard.TargetProperty="Offset"/>
		<DoubleAnimation x:Key="LoadAnimOffset1"
                     Duration="0:0:0.25"
                     To="0"
                     Completed="LoadAnimation_Completed"
                     Storyboard.TargetName="OpacityMaskGradStop1"
                     Storyboard.TargetProperty="Offset"/>
		<DoubleAnimation x:Key="DummyAnim"
                     Duration="0:0:0.5"
                     Completed="DummyAnimation_Completed"/>
		<ContextMenu x:Key="TopOptionsMenu">
			<MenuItem Name="ItemMinSidebar" Click="MinimizeSidebar_Click"/>
			<MenuItem Name="ItemProperties" Click="Properties_Click"/>
			<MenuItem Name="ItemAddTile" Click="AddTile_Click"/>
			<MenuItem Name="ItemManageTile" SubmenuOpened="ItemManageTile_SubmenuOpened">
				<MenuItem.Items>
					<MenuItem Header="Test"></MenuItem>
				</MenuItem.Items>
			</MenuItem> 
			<Separator></Separator>
			<MenuItem Name="ItemCancelSidebar" Click="CancelSidebar_Click"/>
		</ContextMenu>
		<DataTemplate x:Key="TileMinimunItemTemplate">
			<ToggleButton Name="OverflowTileItem" Style="{DynamicResource SidebarOverflowTileItem}"
                          ToolTip="{Binding TileTitle}"
						  Click="OverflowTileItem_Click"
						  ContextMenuOpening="OverflowTileItem_ContextMenuOpening"
                          Tag="{Binding}">
				<Image Source="{Binding TileLogo}" Width="16" Height="16"/>
			</ToggleButton>
		</DataTemplate>
	</Window.Resources>
	<Window.OpacityMask>
		<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#00000000" Offset="0"/>
			<GradientStop x:Name="OpacityMaskGradStop1" Color="#00000000" Offset="1"/>
			<GradientStop x:Name="OpacityMaskGradStop" Color="#FF000000" Offset="1"/>
			<GradientStop Color="#FFFFFFFF" Offset="1"/>
		</LinearGradientBrush>
	</Window.OpacityMask>
	<Grid>
		<Grid Name="BackgroundRegion" Background="Transparent" RenderTransformOrigin="0.5, 0.5">
			<Grid.RenderTransform>
				<ScaleTransform ScaleX="{Binding Source={StaticResource CurrentUserConfig}, Path=Direction, Converter={StaticResource DirectionToScaleX}}"/>
			</Grid.RenderTransform>
			<Rectangle Name="BackgroundBlur" Fill="Transparent" IsHitTestVisible="False" SnapsToDevicePixels="True"></Rectangle>
			<Rectangle Name="Background" Style="{DynamicResource Background}"></Rectangle>
			<snt:Slice9Image Name="BackgroundImage1" Style="{DynamicResource BackgroundImageSlice9}"></snt:Slice9Image>
			<Image Name="BackgroundImage" Style="{DynamicResource BackgroundImage}"></Image>
			<Rectangle Name="BackgroundHighlight" Style="{DynamicResource BackgroundHighlight}"></Rectangle>
			<Canvas Name="BackgroundCustom" Style="{DynamicResource BackgroundCustomDraw}"></Canvas>
			<Grid>
				<Line x:Name="BorderLine" 
				  X1="0" Y1="0" X2="0" Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" 
				  Style="{DynamicResource BorderLine}"/>
			</Grid>
		</Grid>
		<Grid Name="Content" Background="{x:Null}">
			<StackPanel Name="Splitter" Style="{DynamicResource TopOptionsPanelSplitter}" RenderTransformOrigin="0.5,0.5">
				<StackPanel.RenderTransform>
					<ScaleTransform ScaleX="{Binding Source={StaticResource CurrentUserConfig}, 
                                         Path=Direction, 
                                         Converter={StaticResource DirectionToScaleX}}"/>
				</StackPanel.RenderTransform>
				<Rectangle IsHitTestVisible="False" Style="{DynamicResource TileSplitterTopBlankFill}"></Rectangle>
				<Line Name="SplitterLine1" Style="{DynamicResource TileSplitterLineTop}"/>
				<Line Name="SplitterLine2" Style="{DynamicResource TileSplitterLineBottom}"/>
				<Rectangle Name="SplitterLineBottomFill" IsHitTestVisible="False" Style="{DynamicResource TileSplitterBottomBlankFill}"></Rectangle>
			</StackPanel>
			<DockPanel Name="MainPanel" Style="{DynamicResource MainPanel}">
				<StackPanel Name="PinnedTilesRegion" Style="{DynamicResource PinnedTilesRegion}"></StackPanel>
				<Grid Name="OverflowTilesRegion" Height="0" DockPanel.Dock="Bottom">
					<StackPanel Name="OverflowTilesRegionContent">
						<StackPanel Style="{DynamicResource TileSplitterPanel}" RenderTransformOrigin="0.5,0.5" Cursor="Arrow">
							<StackPanel.RenderTransform>
								<ScaleTransform ScaleX="{Binding Source={StaticResource CurrentUserConfig}, 
                                         Path=Direction, 
                                         Converter={StaticResource DirectionToScaleX}}"/>
							</StackPanel.RenderTransform>
							<Rectangle IsHitTestVisible="False" Style="{DynamicResource TileSplitterTopBlankFill}"></Rectangle>
							<Line Style="{DynamicResource TileSplitterLineTop}"/>
							<Line Style="{DynamicResource TileSplitterLineBottom}"/>
							<Rectangle IsHitTestVisible="False" Style="{DynamicResource TileSplitterBottomBlankFill}"></Rectangle>
						</StackPanel>
						<ItemsControl Style="{DynamicResource SidebarOverflowTileItemControlContainer}"
						  Name="TileOverflowItems"
						  ItemTemplate="{DynamicResource TileMinimunItemTemplate}"
						  ItemsPanel="{DynamicResource SidebarOverflowTileItemWrapPanel}"
						  />
					</StackPanel>
					<Rectangle IsHitTestVisible="False" Style="{DynamicResource PinnedTileHighlight}">
						<Rectangle.RenderTransform>
							<ScaleTransform ScaleX="{Binding Source={StaticResource CurrentUserConfig}, Path=Direction, Converter={StaticResource DirectionToScaleX}}"/>
						</Rectangle.RenderTransform>
					</Rectangle>
				</Grid>
				<StackPanel Name="TilesRegion" Style="{DynamicResource TilesRegion}"></StackPanel>
			</DockPanel>
			<Grid RenderTransformOrigin="0.5, 0.5" IsHitTestVisible="False">
				<Grid.RenderTransform>
					<ScaleTransform ScaleX="{Binding Source={StaticResource CurrentUserConfig}, 
                                         Path=Direction, 
                                         Converter={StaticResource DirectionToScaleX}}"/>
				</Grid.RenderTransform>
				<Rectangle Name="TileHighlight" Style="{DynamicResource SidebarHighlight}" >
				</Rectangle>
			</Grid>
			<local:TopOptions x:Name="TopOptionsPanel"
				Style="{DynamicResource TopOptionsPanel}"
				ContextMenu="{StaticResource TopOptionsMenu}"
							  ></local:TopOptions>
		</Grid>
	</Grid>
</Window>
