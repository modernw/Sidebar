<Window x:Class="Sidebar.TilePropertiesForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:local="clr-namespace:Sidebar"
        mc:Ignorable="d"
        Title="TileProperties" Height="300" Width="300" MinWidth="200" MinHeight="100">
	<DockPanel LastChildFill="True">
		<DockPanel DockPanel.Dock="Bottom">
			<StackPanel Orientation="Horizontal" Margin="0,5,0,10"
                        HorizontalAlignment="Right">
				<Button Name="TilePropertiesOkButton" Content="OK" MinWidth="75" Height="23" Margin="5,0"/>
				<Button Name="TilePropertiesCancelButton" Content="Cancel" MinWidth="75" Height="23" Margin="5,0,12,0"/>
			</StackPanel>
		</DockPanel>
		<Separator DockPanel.Dock="Bottom" Margin="5,0,5,0" Visibility="Collapsed"></Separator>
		<Grid Name="TilePropertiesContent"></Grid>
    </DockPanel>
</Window>
