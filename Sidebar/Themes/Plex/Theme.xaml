	</Style>
	<!-- Icon Item -->
	<LinearGradientBrush x:Key="TileIconItemHoverBackground" StartPoint="0,0" EndPoint="0,1">
		<GradientStop Color="#1EFFFFFF" Offset="0"/>
		<GradientStop Color="#1EFFFFFF" Offset="1"/>
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="TileIconItemPressedBackground" StartPoint="0,0" EndPoint="0,1">
		<GradientStop Color="#0EFFFFFF" Offset="0"/>
		<GradientStop Color="#0EFFFFFF" Offset="1"/>
	</LinearGradientBrush>
	<SolidColorBrush x:Key="TileIconItemHoverBorderBrush" Color="#1EFFFFFF"/>
	<SolidColorBrush x:Key="TileIconItemPressedBorderBrush" Color="#0EFFFFFF"/>
	<LinearGradientBrush x:Key="TileIconItemWithTextHoverBackground" StartPoint="0,0" EndPoint="0,1">
		<GradientStop Color="#1EFFFFFF" Offset="0"/>
		<GradientStop Color="#1EFFFFFF" Offset="1"/>
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="TileIconItemWithTextPressedBackground" StartPoint="0,0" EndPoint="0,1">
		<GradientStop Color="#0EFFFFFF" Offset="0"/>
		<GradientStop Color="#0EFFFFFF" Offset="1"/>
	</LinearGradientBrush>
	<SolidColorBrush x:Key="TileIconItemWithTextHoverBorderBrush" Color="#1EFFFFFF"/>
	<SolidColorBrush x:Key="TileIconItemWithTextPressedBorderBrush" Color="#0EFFFFFF"/>
	<Style x:Key="TileIconItemButtonStyle" TargetType="ToggleButton">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="Padding" Value="4,4,4,4"></Setter>
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Border x:Name="border"
										Width="{TemplateBinding Width}"
										Height="{TemplateBinding Height}"
										CornerRadius="1"
										BorderThickness="1"
										Background="Transparent"
										BorderBrush="Transparent"
										Opacity="1">
						<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal">
									<Storyboard/>
								</VisualState>
								<VisualState x:Name="MouseOver">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemHoverBackground}"/>
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemHoverBorderBrush}"/>
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Pressed">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemPressedBackground}"/>
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemPressedBorderBrush}"/>
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="TileIconItemTileContainer" TargetType="ItemsControl">
		<Setter Property="Margin" Value="4,3,1,3"></Setter>
	</Style>
	<Style x:Key="TileIconItemWithTextButtonStyle" TargetType="ToggleButton">
		<Setter Property="HorizontalContentAlignment" Value="Stretch"></Setter>
		<Setter Property="Height" Value="24"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Padding" Value="4,4,4,4"></Setter>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Border x:Name="border"
										Width="{TemplateBinding Width}"
										Height="{TemplateBinding Height}"
										CornerRadius="1"
										BorderThickness="1"
										Background="Transparent"
										BorderBrush="Transparent"
										Opacity="1">
						<ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Top"/>
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<!-- 正常状态：无背景，无边框（已默认透明） -->
								<VisualState x:Name="Normal">
									<Storyboard>
										<!-- 可以什么都不做，保持透明 -->
									</Storyboard>
								</VisualState>
								<!-- 鼠标悬浮：显示半透明背景和边框 -->
								<VisualState x:Name="MouseOver">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemWithTextHoverBackground}"/>
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemWithTextHoverBorderBrush}"/>
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<!-- 按下：显示较深的背景和边框 -->
								<VisualState x:Name="Pressed">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemWithTextPressedBackground}"/>
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileIconItemWithTextPressedBorderBrush}"/>
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<!-- Tray -->
	<Style x:Key="TileIconItemForTrayTile" TargetType="ToggleButton" BasedOn="{StaticResource TileIconItemButtonStyle}">
		<Setter Property="Width" Value="24"></Setter>
		<Setter Property="Height" Value="24"></Setter>
	</Style>
	<Style x:Key="TileIconItemTileContainerForTrayTile" TargetType="ItemsControl" BasedOn="{StaticResource TileIconItemTileContainer}"></Style>
	<Style x:Key="TileIconItemWithTextForTrayTile" TargetType="ToggleButton" BasedOn="{StaticResource TileIconItemWithTextButtonStyle}">
		<Setter Property="Height" Value="Auto"></Setter>
