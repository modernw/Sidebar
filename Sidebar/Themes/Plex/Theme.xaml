	<!-- Search -->
	<Style x:Key="TileSearchTilePanel" TargetType="Grid">
		<Setter Property="Margin" Value="3,9,8,12"></Setter>
		<Setter Property="Height" Value="23"></Setter>
	</Style>
	<Style x:Key="TileSearchTextboxBorder" TargetType="Border">
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="9"/>
		<Setter Property="BorderBrush">
			<Setter.Value>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
					<GradientStop Offset="0" Color="#B5C6DC"/>
					<GradientStop Offset="0.328" Color="#99B4DA"/>
					<GradientStop Offset="0.336" Color="#97B3D9"/>
					<GradientStop Offset="0.872" Color="Transparent"/>
					<GradientStop Offset="1" Color="Transparent"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="TileSearchTextboxBorderInner" TargetType="Border">
		<Setter Property="BorderThickness" Value="1"></Setter>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="BorderBrush" Value="#7F9DB9"></Setter>
	</Style>
	<Style x:Key="TileSearchTextboxInnerClip" TargetType="Grid">
		<Setter Property="Tag" Value="8" />
	</Style>
	<Style x:Key="TileSearchTextboxBackground" TargetType="Rectangle">
		<Setter Property="Fill">
			<Setter.Value>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
					<GradientStop Offset="0" Color="White"/>
					<GradientStop Offset="0.3223" Color="White"/>
					<GradientStop Offset="0.3306" Color="#FCFDFD"/>
					<GradientStop Offset="0.9091" Color="#345D98"/>
					<GradientStop Offset="1" Color="#345D98"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="TileSearchTextboxPlaceholder" TargetType="TextBlock">
		<Setter Property="Margin" Value="3,4,0,0"></Setter>
		<Setter Property="Foreground" Value="Black"></Setter>
	</Style>
	<Style x:Key="TileSearchTextboxTextInput" TargetType="TextBox">
		<Setter Property="BorderThickness" Value="0"></Setter>
		<Setter Property="Padding" Value="3,2,0,0"></Setter>
		<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
		<Setter Property="FontSize" Value="{DynamicResource GlobalNormalFontSize}" />
		<Setter Property="Background" Value="Transparent"></Setter>
		<Setter Property="Foreground" Value="Black"></Setter>
	</Style>
	<Style x:Key="TileSearchTextboxInnerShadowRegion" TargetType="Grid">
