<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Sidebar"
					xmlns:snt="clr-namespace:Sidebar;assembly=Native"
					xmlns:s="clr-namespace:System;assembly=mscorlib">
	<!-- Includes -->
	<!-- Options -->
	<s:Boolean x:Key="EnableBlur">true</s:Boolean>
	<s:Boolean x:Key="EnableShadow">false</s:Boolean>
	<!-- Styles -->
	<SolidColorBrush x:Key="GlobalForegroundBrush" Color="White" />
	<s:Double x:Key="GlobalFontSize">10</s:Double>
	<s:Double x:Key="GlobalNormalFontSize">10</s:Double>
	<s:Double x:Key="GlobalNormalFontSizeSmall">9</s:Double>
	<!-- Sidebar -->
	<Style x:Key="Background" TargetType="Rectangle">
		<Setter Property="Fill">
			<Setter.Value>
				<LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
					<GradientStop Color="#99000000" Offset="0"/>
					<GradientStop Color="#FF000000" Offset="1"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="BackgroundHighlight" TargetType="Rectangle">
		<Setter Property="HorizontalAlignment" Value="Left"></Setter>
		<Setter Property="Stretch" Value="Fill"/>
		<Setter Property="Width" Value="200"/>
		<Setter Property="Fill">
			<Setter.Value>
				<RadialGradientBrush RadiusX="0.5" RadiusY="0.9" Center="-0.3,0.5" GradientOrigin="0.15,0.5" Opacity="0.08">
					<GradientStop Color="#FFFFFFFF" Offset="0"/>
					<GradientStop Color="#00FFFFFF" Offset="1"/>
					<GradientStop Color="#FFFFFFFF" Offset="0.90"/>
				</RadialGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="SidebarHighlight" TargetType="Rectangle">
		<Setter Property="Stretch" Value="Fill"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="Width" Value="2"/>
		<Setter Property="Fill">
			<Setter.Value>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,0" Opacity="1">
					<GradientStop Color="#BB000000" Offset="0.0"/>
					<GradientStop Color="#BB000000" Offset="0.5"/>
					<GradientStop Color="#66FFFFFF" Offset="0.5"/>
					<GradientStop Color="#66FFFFFF" Offset="1"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="BorderLine" TargetType="Line">
		<Setter Property="Stroke" Value="Transparent"></Setter>
	</Style>
	<Style x:Key="TileSplitterPanel" TargetType="StackPanel">
		<Setter Property="DockPanel.Dock" Value="Bottom"/>
		<Setter Property="Height" Value="4"/>
		<Setter Property="Cursor" Value="SizeNS"/>
		<Setter Property="Background" Value="#00000000"/>
	</Style>
	<Style x:Key="TileSplitterLineTop" TargetType="Line">
		<Setter Property="Opacity" Value="0.7"/>
		<Setter Property="X1" Value="0"/>
		<Setter Property="X2" Value="200"/>
		<Setter Property="Stretch" Value="UniformToFill"/>
		<Setter Property="StrokeThickness" Value="1"/>
		<Setter Property="Stroke" Value="Gray"/>
		<Setter Property="OpacityMask">
			<Setter.Value>
				<LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
					<GradientStop Color="#FF000000" Offset="0.0"/>
					<GradientStop Color="#00000000" Offset="1.0"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="TileSplitterLineBottom" TargetType="Line">
		<Setter Property="Opacity" Value="0.7"/>
		<Setter Property="X1" Value="0"/>
		<Setter Property="X2" Value="200"/>
		<Setter Property="Stretch" Value="UniformToFill"/>
		<Setter Property="StrokeThickness" Value="1"/>
		<Setter Property="Stroke" Value="Black"/>
		<Setter Property="OpacityMask">
			<Setter.Value>
				<LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
					<GradientStop Color="#FF000000" Offset="0.0"/>
					<GradientStop Color="#00000000" Offset="1.0"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="TileSplitterLineTopLighting" TargetType="Line" BasedOn="{StaticResource TileSplitterLineTop}">
		<Setter Property="OpacityMask">
			<Setter.Value>
				<LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
					<GradientStop Color="#FF000000" Offset="0.0"/>
					<GradientStop Color="#AA000000" Offset="1.0"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="TileSplitterLineBottomLighting" TargetType="Line" BasedOn="{StaticResource TileSplitterLineBottom}">
		<Setter Property="OpacityMask">
			<Setter.Value>
				<LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
					<GradientStop Color="#FF000000" Offset="0.0"/>
					<GradientStop Color="#AA000000" Offset="1.0"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="TileSplitterTopBlankFill" TargetType="Rectangle">
		<Setter Property="Height" Value="2"></Setter>
	</Style>
	<Style x:Key="TileSplitterTopBlankFillLighting" TargetType="Rectangle" BasedOn="{StaticResource TileSplitterTopBlankFill}"></Style>
	<Style x:Key="MainPanel" TargetType="DockPanel">
		<Setter Property="Margin" Value="0,19,0,0"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="VerticalAlignment" Value="Stretch"/>
		<Setter Property="LastChildFill" Value="True"/>
	</Style>
	<!-- Top Options -->
	<Style x:Key="TopOptionsText" TargetType="TextBlock" BasedOn="{StaticResource GlobalTextBlockTextDisplay}">
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontSize" Value="9" />
	</Style>
	<Style x:Key="TopOptionsIcon" TargetType="Polygon">
		<Setter Property="Opacity" Value="0.45" />
		<Setter Property="Stroke" Value="#020202" />
		<Setter Property="StrokeThickness" Value="1" />
		<Setter Property="Fill" Value="White" />
		<Setter Property="Margin" Value="2,1,2,0" />
		<Setter Property="RenderTransformOrigin" Value="0.556,0.9" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Setter Property="StrokeStartLineCap" Value="Round" />
		<Setter Property="StrokeEndLineCap" Value="Round" />
		<Setter Property="StrokeLineJoin" Value="Round" />
	</Style>
	<Style x:Key="TopOptionsPanel" TargetType="FrameworkElement">
		<Setter Property="VerticalAlignment" Value="Top"/>
		<Setter Property="Height" Value="17"/>
	</Style>
	<Style x:Key="TopOptionsPanelSplitter" TargetType="StackPanel">
		<Setter Property="Margin" Value="0,17,0,0"/>
		<Setter Property="VerticalAlignment" Value="Top"/>
		<Setter Property="Cursor" Value="Arrow"/>
		<Setter Property="Background" Value="#00000000"/>
		<Setter Property="Height" Value="4"/>
	</Style>
	<!-- Tile -->
	<Style x:Key="TilePanel" TargetType="DockPanel">
		<Setter Property="Background" Value="#00000000"/>
	</Style>
	<Style x:Key="TileHeader" TargetType="DockPanel">
		<Setter Property="Visibility" Value="Collapsed"/>
	</Style>
	<Style x:Key="TileIcon" TargetType="Image">
		<Setter Property="DockPanel.Dock" Value="Right"/>
		<Setter Property="Height" Value="15"/>
		<Setter Property="Width" Value="15"/>
	</Style>
	<Style x:Key="TileTitle" TargetType="TextBlock" BasedOn="{StaticResource GlobalTextBlockTextDisplay}">
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalAlignment" Value="Left"/>
		<Setter Property="Margin" Value="5,0,5,0"/>
		<Setter Property="FontSize" Value="10"/>
		<Setter Property="Foreground" Value="White"/>
	</Style>
	<Style x:Key="TileContent" TargetType="Grid">
		<Setter Property="Background" Value="#00000000"/>
		<Setter Property="Margin" Value="1,0,0,0"/>
	</Style>
	<Style x:Key="TileFlyoutIcon" TargetType="Polygon">
		<Setter Property="Opacity" Value="0" />
		<Setter Property="Stroke" Value="#020202" />
		<Setter Property="StrokeThickness" Value="1" />
		<Setter Property="Fill" Value="White" />
		<Setter Property="Margin" Value="1,2,1,0" />
		<Setter Property="RenderTransformOrigin" Value="0.556,0.9" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
		<Setter Property="StrokeStartLineCap" Value="Round" />
		<Setter Property="StrokeEndLineCap" Value="Round" />
		<Setter Property="StrokeLineJoin" Value="Round" />
	</Style>
	<Style x:Key="PinnedTileIcon" TargetType="Image" BasedOn="{StaticResource TileIcon}">
	</Style>
	<Style x:Key="PinnedTileTitle" TargetType="TextBlock" BasedOn="{StaticResource TileTitle}">
	</Style>
	<Style x:Key="PinnedTileHeader" TargetType="DockPanel">
		<Setter Property="Visibility" Value="Collapsed"/>
	</Style>
	<Style x:Key="PinnedTileFlyoutIcon" TargetType="Polygon" BasedOn="{StaticResource TileFlyoutIcon}">
		<Setter Property="Margin" Value="1,4,1,0" />
	</Style>
	<Style x:Key="PinnedTileContent" TargetType="Grid" BasedOn="{StaticResource TileContent}">
		<Setter Property="Margin" Value="0,0,1,0"/>
	</Style>
	<Style x:Key="PinnedTileSplitterPanel" TargetType="StackPanel" BasedOn="{StaticResource TileSplitterPanel}">
		<Setter Property="DockPanel.Dock" Value="Top"/>
	</Style>
	<!-- Flyout -->
	<Style x:Key="FlyoutBorderBehind" TargetType="Rectangle">
		<Setter Property="Stroke" Value="#802D2D2D"/>
		<Setter Property="StrokeThickness" Value="1,1,0,1"/>
	</Style>
	<Style x:Key="FlyoutBackgroundFill" TargetType="Rectangle">
		<Setter Property="Opacity" Value="0.6"/>
		<Setter Property="Margin" Value="1,1,0,1"/>
		<Setter Property="Fill" Value="Black"/>
		<Setter Property="Stroke" Value="LightGray"/>
	</Style>
	<Style x:Key="FlyoutBorder" TargetType="Rectangle">
		<Setter Property="Stroke" Value="#800D0D0D"/>
		<Setter Property="StrokeThickness" Value="1"></Setter>
		<Setter Property="Margin" Value="1,1,0,1"></Setter>
	</Style>
	<Style x:Key="FlyoutBackgroundHighlight" TargetType="Rectangle">
		<Setter Property="Opacity" Value="0.9"/>
		<Setter Property="Margin" Value="-40,1,0,1"/>
		<Setter Property="Fill">
			<Setter.Value>
				<RadialGradientBrush RadiusX="0.8" RadiusY="2" Center="-0.5,0.5" GradientOrigin="0,0.5" Opacity="1">
					<GradientStop Color="#00FFFFFF" Offset="1"/>
					<GradientStop Color="#19FFFFFF" Offset="0.99"/>
					<GradientStop Color="#00FFFFFF" Offset="0.49"/>
					<GradientStop Color="#B2A9A9A9" Offset="0.5"/>
				</RadialGradientBrush>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="FlyoutBackgroundHighlight1" TargetType="Rectangle">
	</Style>
	<Style x:Key="FlyoutHeaderOptionsBar" TargetType="FrameworkElement">
		<Setter Property="Height" Value="14"></Setter>
		<Setter Property="Margin" Value="4,1,4,0"></Setter>
		<Setter Property="MinHeight" Value="0"></Setter>
	</Style>
	<Style x:Key="FlyoutHeaderOptionsIcon" TargetType="Polygon" BasedOn="{StaticResource TopOptionsIcon}">
		<Setter Property="Margin" Value="2,0,0,0"></Setter>
	</Style>
	<Style x:Key="FlyoutContent" TargetType="Grid">
		<Setter Property="Margin" Value="4,17,4,4"></Setter>
	</Style>
	<!-- Drag -->
	<Style x:Key="DragPlaceholder" TargetType="Rectangle">
		<Setter Property="Margin" Value="0,0,0,0"/>
		<Setter Property="Stroke" Value="#B3FFFFFF"/>
		<Setter Property="StrokeThickness" Value="1.5"/>
		<Setter Property="Opacity" Value="1"/>
		<Setter Property="Fill">
			<Setter.Value>
				<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
					<GradientStop Color="#33FFFFFF" Offset="0"/>
					<GradientStop Color="#18FFFFFF" Offset="1"/>
				</LinearGradientBrush>
			</Setter.Value>
		</Setter>
		<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
		<Setter Property="RenderTransform">
			<Setter.Value>
				<ScaleTransform ScaleX="1" ScaleY="1"/>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<EventTrigger RoutedEvent="Rectangle.Loaded">
				<BeginStoryboard>
					<Storyboard Duration="0:0:0.3">
						<DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="1" To="0.2"/>
						<DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                     From="1" To="0.6"/>
						<DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                     From="1" To="0.6"/>
					</Storyboard>
				</BeginStoryboard>
			</EventTrigger>
		</Style.Triggers>
	</Style>
	<!-- Tiles -->
	<!-- Clock:ClockFace -->
	<Style x:Key="TileClockClockContainer" TargetType="Grid">
		<Setter Property="Width" Value="260"></Setter>
		<Setter Property="Height" Value="260"></Setter>
	</Style>
	<Style x:Key="TileClockFace" TargetType="Image">
		<Setter Property="Width" Value="260"></Setter>
		<Setter Property="Height" Value="260"></Setter>
		<Setter Property="Source" Value="Images\ClockFace.png"></Setter>
	</Style>
	<Style x:Key="TileClockHourHand" TargetType="Image">
		<Setter Property="Height" Value="95" />
		<Setter Property="Margin" Value="0,0,0,50"/>
		<Setter Property="RenderTransformOrigin" Value="0.5,0.78"/>
		<Setter Property="Source" Value="Images\Hour.png"></Setter>
	</Style>
	<Style x:Key="TileClockMinuteHand" TargetType="Image">
		<Setter Property="Height" Value="125"></Setter>
		<Setter Property="Margin" Value="0,0,0,85"></Setter>
		<Setter Property="RenderTransformOrigin" Value="0.5,0.845"/>
		<Setter Property="Source" Value="Images\Minute.png"></Setter>
	</Style>
	<Style x:Key="TileClockSecondHand" TargetType="Image">
		<Setter Property="Height" Value="128"></Setter>
		<Setter Property="Margin" Value="0,0,0,72"></Setter>
		<Setter Property="RenderTransformOrigin" Value="0.5,0.778"/>
		<Setter Property="Source" Value="Images\Second.png"></Setter>
	</Style>
	<Style x:Key="TileClockHub" TargetType="Image">
		<Setter Property="Width" Value="12"></Setter>
		<Setter Property="Height" Value="12"></Setter>
		<Setter Property="Source" Value="Images\Hub.png"></Setter>
	</Style>
	<Style x:Key="TileClockCrystal" TargetType="Image">
		<Setter Property="Width" Value="260"></Setter>
		<Setter Property="Height" Value="260"></Setter>
		<Setter Property="Source" Value="Images\Crystal.png"></Setter>
	</Style>
	<!-- Tray & QuickLaunch IconItem -->
	<Style x:Key="TileIconItemButtonStyle" TargetType="ToggleButton">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Grid Width="{TemplateBinding Width}"
                      Height="{TemplateBinding Height}">

						<snt:Slice9Image x:Name="HoverImage"
                                     Source="{DynamicResource TileIconItemHoverImage}"
                                     SliceThickness="4"
                                     Opacity="0"/>

						<snt:Slice9Image x:Name="PressedImage"
                                     Source="{DynamicResource TileIconItemActiveImage}"
                                     SliceThickness="4"
                                     Opacity="0"/>

						<ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
					</Grid>

					<ControlTemplate.Triggers>

						<!-- Hover：只有未按下时显示 -->
						<MultiTrigger>
							<MultiTrigger.Conditions>
								<Condition Property="IsMouseOver" Value="True"/>
								<Condition Property="IsPressed" Value="False"/>
							</MultiTrigger.Conditions>

							<Setter TargetName="HoverImage"
                                Property="Opacity"
                                Value="1"/>
						</MultiTrigger>

						<!-- Pressed：按下时显示 -->
						<Trigger Property="IsPressed"
                             Value="True">
							<Setter TargetName="PressedImage"
                                Property="Opacity"
                                Value="1"/>
						</Trigger>

					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<!-- QuickLaunch -->
	<Style x:Key="TileIconItemForQuickLaunchTile" TargetType="ToggleButton" BasedOn="{StaticResource TileIconItemButtonStyle}">
		<Setter Property="Width" Value="28"/>
		<Setter Property="Height" Value="28"/>
	</Style>
	<Style x:Key="TileIconItemWithTextForQuickLaunchTile" TargetType="ToggleButton" BasedOn="{StaticResource TileIconItemWithTextButtonStyle}"></Style>
</ResourceDictionary>