<UserControl x:Class="WindowsModern.TrayTile.TilePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.TrayTile"
			 ContextMenuOpening="TilePanel_ContextMenuOpening"
             mc:Ignorable="d" Loaded="TilePanel_Loaded" Unloaded="TilePanel_Unloaded"
             d:DesignHeight="300" d:DesignWidth="300">

	<UserControl.Resources>
		<!-- 背景渐变色，仅鼠标悬浮/按下时显示 -->
		<LinearGradientBrush x:Key="HoverBackground" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#4DABABAB" Offset="0"/>
			<GradientStop Color="#70727272" Offset="1"/>
		</LinearGradientBrush>

		<LinearGradientBrush x:Key="PressedBackground" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#39565656" Offset="0"/>
			<GradientStop Color="#398C8C8C" Offset="1"/>
		</LinearGradientBrush>

		<SolidColorBrush x:Key="HoverBorderBrush" Color="#44E9E9E9"/>
		<SolidColorBrush x:Key="PressedBorderBrush" Color="#47DADADA"/>

		<!-- 修改后的按钮样式：图标始终可见，背景只在悬浮/按下时出现 -->
		<Style x:Key="IconButtonStyle" TargetType="ToggleButton">
			<Setter Property="Width" Value="24"/>
			<Setter Property="Height" Value="24"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ToggleButton">
						<!-- Opacity 始终为 1，背景初始为透明 -->
						<Border x:Name="border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="1"
                                BorderThickness="1"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Opacity="1">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
							<VisualStateManager.VisualStateGroups>
								<VisualStateGroup x:Name="CommonStates">
									<!-- 正常状态：无背景，无边框（已默认透明） -->
									<VisualState x:Name="Normal">
										<Storyboard>
											<!-- 可以什么都不做，保持透明 -->
										</Storyboard>
									</VisualState>

									<!-- 鼠标悬浮：显示半透明背景和边框 -->
									<VisualState x:Name="MouseOver">
										<Storyboard>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="Background">
												<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource HoverBackground}"/>
											</ObjectAnimationUsingKeyFrames>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="BorderBrush">
												<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource HoverBorderBrush}"/>
											</ObjectAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState>

									<!-- 按下：显示较深的背景和边框 -->
									<VisualState x:Name="Pressed">
										<Storyboard>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="Background">
												<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource PressedBackground}"/>
											</ObjectAnimationUsingKeyFrames>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="border"
                                                                           Storyboard.TargetProperty="BorderBrush">
												<DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource PressedBorderBrush}"/>
											</ObjectAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState>
								</VisualStateGroup>
							</VisualStateManager.VisualStateGroups>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<DataTemplate x:Key="TrayIconTemplate">
			<ToggleButton Style="{StaticResource IconButtonStyle}"
                          ToolTip="{Binding TooltipText}"
                          Command="{Binding LeftClickCommand}"
                          Tag="{Binding}"
                         
                          MouseDoubleClick="ToggleButton_MouseDoubleClick">
				<Image Source="{Binding IconSource}" Width="16" Height="16"/>
			</ToggleButton>
		</DataTemplate>

		<ItemsPanelTemplate x:Key="IconWrapPanel">
			<WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top"/>
		</ItemsPanelTemplate>
	</UserControl.Resources>

	<Grid Height="Auto">
		<ItemsControl Margin="5,3,1,3"
                      Name="SystemTrayContainer"
                      ItemsSource="{Binding TrayIcons}"
                      ItemTemplate="{StaticResource TrayIconTemplate}"
                      ItemsPanel="{StaticResource IconWrapPanel}"
					  PreviewMouseRightButtonDown="SystemTrayContainer_PreviewMouseRightButtonDown"/>
	</Grid>

</UserControl>