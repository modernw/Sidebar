<UserControl x:Class="WindowsModern.TrayTile.FlyoutPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.TrayTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>
		<DataTemplate x:Key="ItemTemplate">
			<ToggleButton Style="{DynamicResource TileIconItemWithTextForTrayTile}"
                          ToolTip="{Binding ToolTip}"
                          Tag="{Binding}"
                          Click="ToggleButton_Click"
						  MouseDoubleClick="ToggleButton_MouseDoubleClick"
						  MouseEnter="ToggleButton_MouseEnter"
						  MouseLeave="ToggleButton_MouseLeave"
						  TouchEnter="ToggleButton_TouchEnter"
						  TouchLeave="ToggleButton_TouchLeave">
				<StackPanel Margin="4,4,4,4" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Stretch">
					<Image Source="{Binding Icon}" VerticalAlignment="Top" Width="16" Height="16" Stretch="Uniform"/>
					<TextBlock Text="{Binding ToolTip}" Style="{DynamicResource TileIconItemWithTextItemTextPart}"/>
				</StackPanel>
			</ToggleButton>
		</DataTemplate>
	</UserControl.Resources>
	<Grid Width="Auto" Height="Auto" MaxHeight="400" MaxWidth="500">
		<ScrollViewer VerticalScrollBarVisibility="Auto" Style="{DynamicResource AutoHideScrollViewer}">
			<ItemsControl
                      Name="ItemContainer"
                      ItemsSource="{Binding TrayIcons}"
                      ItemTemplate="{DynamicResource ItemTemplate}"
                      ItemsPanel="{DynamicResource TileIconItemWithTextWrapPanel}"
                      PreviewMouseRightButtonDown="ItemContainer_PreviewMouseRightButtonDown"/>
		</ScrollViewer>
	</Grid>
</UserControl>
