<UserControl x:Class="ClockTile.OptionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClockTile"
             mc:Ignorable="d" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>
		<Style x:Key="TileClockFontIconButton" TargetType="Button">
			<Setter Property="FontFamily" Value="Marlett, Webdings, Wingdings, Wingdings 2, Wingdings 3, Segoe UI Symbol, Segoe MDL2 Assets"/>
			<Setter Property="FontSize" Value="8"></Setter>
			<Setter Property="MinWidth" Value="10"></Setter>
		</Style>
	</UserControl.Resources>
    <Grid>
		<TabControl Margin="6,6,6,6">
			<TabItem Header="Alarm" Name="TagAlarm">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="19,19,19,19">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<CheckBox VerticalAlignment="Center" Name="EnableAlarm">Alarm is set for</CheckBox>
							<TextBlock Text=" " />
							<local:TimePicker x:Name="AlarmTime" EnableSecond="False"></local:TimePicker>
						</StackPanel>
						<CheckBox Margin="0,5,0,0" Name="RepeatEveryDay">Repeat every day</CheckBox>
						<TextBlock Margin="0,20,0,5" Name="SongToPlay">Song to play</TextBlock>
						<ComboBox Name="SoundList"></ComboBox>
						<TextBlock Margin="0,5,0,5" Name="LabelVolume">Volume</TextBlock>
						<DockPanel>
							<Button Name="PlayButton" DockPanel.Dock="Right" Width="20" FontFamily="Webdings" FontSize="11" Style="{DynamicResource TileClockFontIconButton}" Click="PlayButton_Click">4</Button>
							<Slider Name="VolumeControl" Margin="0,0,10,0" Minimum="1" Maximum="100" ValueChanged="VolumeControl_ValueChanged"></Slider>
						</DockPanel>
						<TextBlock Margin="0,20,0,5" Name="LabelMessage">Message</TextBlock>
						<TextBox Height="46" Name="AlarmMessage" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"></TextBox>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
			<TabItem Header="Faces" Name="TagFaces">
				<DockPanel Margin="16,16,16,16">
					<TextBlock DockPanel.Dock="Top" Margin="0,0,0,2" Name="LabelClockLayout">Clock layout</TextBlock>
					<ListBox Name="TileLayoutList" SelectionMode="Single" HorizontalContentAlignment="Center">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<local:SidebarTileContainer 
									ContainerContent="{Binding Value.Element}"
									Width="150" Height="Auto"
									Margin="5" />
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</DockPanel>
			</TabItem>
			<TabItem Header="International" Name="TagInternational">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<Grid Margin="19,19,19,19">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
               Margin="0,0,0,5" Text="Time Zone" Name="LabelTimeZone"/>
						<RadioButton Grid.Row="1" Grid.Column="0" 
									 Margin="0,0,0,5" Name="RadioUseLocal"
                 VerticalAlignment="Center" Content="Local"/>
						<Button Grid.Row="1" Grid.Column="1"
								Margin="0,0,0,5" Padding="5,4,5,4"
								Name="OpenControlPanel"
            HorizontalAlignment="Right" Content="Change time zone..." Click="OpenControlPanel_Click"/>
						<RadioButton Grid.Row="2" Grid.ColumnSpan="2" 
									 Name="UseCuston"
									 Margin="0,0,0,5" Content="International"/>
						<ComboBox Name="TimeZoneList" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,5,0,0"/>
					</Grid>
				</ScrollViewer>
			</TabItem>
		</TabControl>
    </Grid>
</UserControl>
