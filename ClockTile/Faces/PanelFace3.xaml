<UserControl x:Class="ClockTile.Faces.PanelFace3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:p="clr-namespace:ClockTile"
             xmlns:local="clr-namespace:ClockTile.Faces"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Style="{DynamicResource TileClockPanelFace3}">
		<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
			<p:ShortTimeText x:Name="ClockShortTime" HorizontalContentAlignment="Left"></p:ShortTimeText>
		</StackPanel>
    </Grid>
</UserControl>
