<UserControl x:Class="ClockTile.Faces.PanelFace4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClockTile.Faces"
			 xmlns:p="clr-namespace:ClockTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>

	</UserControl.Resources>
	<Grid Style="{DynamicResource TileClockPanelFace4}">
		<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
			<StackPanel>
				<p:ShortTimeText x:Name="ClockShortTime" HorizontalContentAlignment="Left"  Style="{DynamicResource TileClockPanelShortTimeText4}"></p:ShortTimeText>
				<TextBlock Name="ClockDayInWeek" Style="{DynamicResource TileClockPanelCommonText4}">Sunday</TextBlock>
				<TextBlock Name="ClockDate" Style="{DynamicResource TileClockPanelCommonText4}">May 11, 2026</TextBlock>
			</StackPanel>
		</StackPanel>
	</Grid>
</UserControl>
