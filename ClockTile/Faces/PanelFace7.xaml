<UserControl x:Class="ClockTile.Faces.PanelFace7"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClockTile.Faces"
			 xmlns:p="clr-namespace:ClockTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Style="{DynamicResource TileClockPanelFace7}">
		<DockPanel LastChildFill="True">
			<p:ClockControl x:Name="ClockPart" Style="{DynamicResource TileClockPanelClock7}"></p:ClockControl>
			<StackPanel Style="{DynamicResource TileClockPanelTextPart5}">
				<p:ShortTimeText x:Name="ShortTime" Style="{DynamicResource TileClockPanelShortTimeText6}"></p:ShortTimeText>
				<TextBlock Name="Date" Style="{DynamicResource TileClockPanelCommonTextLeft}">May 11</TextBlock>
			</StackPanel>
		</DockPanel>
	</Grid>
</UserControl>
