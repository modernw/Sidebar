<UserControl x:Class="ClockTile.Faces.PanelFace1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClockTile.Faces"
			 xmlns:p="clr-namespace:ClockTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>

	</UserControl.Resources>
	<Grid Style="{DynamicResource TileClockPanelFace1}">
		<DockPanel>
			<Grid Height="2" DockPanel.Dock="Top"></Grid>
			<TextBlock Name="ClockDateTime" DockPanel.Dock="Bottom" Style="{DynamicResource TileClockPanelCommonText}">18 Jan., 2015.</TextBlock>
			<p:ClockControl x:Name="ClockCtrl"></p:ClockControl>
		</DockPanel>
    </Grid>
</UserControl>
