<UserControl x:Class="ClockTile.NumberInputBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClockTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>
		<Style x:Key="TileClockNumberInputBoxChangeButton" TargetType="Button">
			<Setter Property="FontFamily" Value="Marlett, Webdings, Wingdings, Wingdings 2, Wingdings 3, Segoe UI Symbol, Segoe MDL2 Assets"/>
			<Setter Property="FontSize" Value="8"></Setter>
			<Setter Property="MinWidth" Value="10"></Setter>
		</Style>
	</UserControl.Resources>
    <Grid>
		<DockPanel VerticalAlignment="Center">
			<StackPanel Orientation="Vertical" Margin="2,0,0,0" DockPanel.Dock="Right">
				<Button x:Name="IncreaseButton" 
						Style="{DynamicResource TileClockNumberInputBoxChangeButton}"
						Content="5"
						Click="IncreaseButton_Click"
						ToolTip="Up"/>
				<Button x:Name="DecreaseButton" 
						Style="{DynamicResource TileClockNumberInputBoxChangeButton}"
						Content="6"
						Click="DecreaseButton_Click"
						ToolTip="Down"/>
			</StackPanel>
			<TextBox x:Name="InputTextBox" 
					 TextAlignment="Center"
					 VerticalContentAlignment="Center"
					 PreviewTextInput="InputTextBox_PreviewTextInput"
					 TextChanged="InputTextBox_TextChanged"
					 LostFocus="InputTextBox_LostFocus"></TextBox>
		</DockPanel>
	</Grid>
</UserControl>
