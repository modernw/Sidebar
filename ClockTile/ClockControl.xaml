<UserControl x:Class="ClockTile.ClockControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClockTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">
	<Grid>
		<Viewbox>
			<Grid Name="ClockContainer" Style="{DynamicResource TileClockClockContainer}">
				<Image Name="ClockFaceBack" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockFace}"></Image>
				<Image Name="HourHand" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockHourHand}">
					<Image.RenderTransform>
						<RotateTransform />
					</Image.RenderTransform>
				</Image>
				<Image Name="MinuteHand" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockMinuteHand}">
					<Image.RenderTransform>
						<RotateTransform />
					</Image.RenderTransform>
				</Image>
				<Image Name="ClockHub" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockHub}"></Image>
				<Image Name="SecondHand" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockSecondHand}">
					<Image.RenderTransform>
						<RotateTransform />
					</Image.RenderTransform>
				</Image>
				<Image Name="ClockCrystal" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockCrystal}"></Image>
			</Grid>
		</Viewbox>
    </Grid>
</UserControl>
