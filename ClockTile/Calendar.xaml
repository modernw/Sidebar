<UserControl x:Class="ClockTile.Calendar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClockTile"
			 xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             mc:Ignorable="d" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid>
		<Viewbox>
			<Border Style="{DynamicResource TileClockCalendarBorder}">
				<DockPanel Style="{DynamicResource TileClockCalendarContainer}">
					<Image Name="MonthImage" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockCalendarMonthImage}"></Image>
					<Grid>
						<Calendar Name="MonthCalendar" Style="{DynamicResource TileClockCalendarItem}" DisplayDateChanged="MonthCalendar_DisplayDateChanged">
						</Calendar>
					</Grid>
				</DockPanel>
			</Border>
		</Viewbox>
    </Grid>
</UserControl>
