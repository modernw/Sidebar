<Window x:Class="ThemeEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThemeEditor"
        xmlns:icsa="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d" Closed="Window_Closed" Closing="Window_Closing"
        Title="MainWindow" Height="508.154" Width="677.116">
	<Window.Resources>
		<Style x:Key="ButtonStyle" TargetType="Button">
			<Setter Property="Width" Value="Auto"/>
			<Setter Property="Height" Value="Auto"/>
			<Setter Property="Padding" Value="5"/>
			<Setter Property="VerticalAlignment" Value="Top"/>
			<Setter Property="HorizontalAlignment" Value="Left"/>
			<Setter Property="Margin" Value="5,5,5,0"/>
		</Style>
		<DrawingBrush x:Key="ChessboardBrush" 
                  Viewport="0,0,10,10" 
                  ViewportUnits="Absolute" 
                  TileMode="Tile">
			<DrawingBrush.Drawing>
				<DrawingGroup>
					<!-- 整个10x10区域为浅灰色 -->
					<GeometryDrawing Brush="LightGray">
						<GeometryDrawing.Geometry>
							<RectangleGeometry Rect="0,0,10,10" />
						</GeometryDrawing.Geometry>
					</GeometryDrawing>
					<!-- 两个白色方块组合 -->
					<GeometryDrawing Brush="White">
						<GeometryDrawing.Geometry>
							<GeometryGroup>
								<RectangleGeometry Rect="0,0,5,5" />
								<RectangleGeometry Rect="5,5,5,5" />
							</GeometryGroup>
						</GeometryDrawing.Geometry>
					</GeometryDrawing>
				</DrawingGroup>
			</DrawingBrush.Drawing>
		</DrawingBrush>
	</Window.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<DockPanel Grid.Row="0" Height="36" HorizontalAlignment="Stretch">
			<TextBlock VerticalAlignment="Center" Margin="5,0,5,0">File Source:</TextBlock>
			<Button Name="SaveButton" Style="{StaticResource ButtonStyle}" Click="SaveButton_Click" DockPanel.Dock="Right">Save</Button>
			<Button Name="LoadButton" Style="{StaticResource ButtonStyle}" Click="LoadButton_Click" DockPanel.Dock="Right">Load</Button>
			<Button Name="BrowseButton" Style="{StaticResource ButtonStyle}" Click="BrowseButton_Click" DockPanel.Dock="Right">Browse...</Button>
			<TextBox Name="FilePath" Padding="5" Margin="5,0,5,0" VerticalAlignment="Center" MinWidth="100"/>
		</DockPanel>
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="1.5*"/>
			</Grid.ColumnDefinitions>
			<DockPanel Grid.Column="0">
				<StatusBar DockPanel.Dock="Bottom">
					<StatusBarItem Name="XamlStatusItem">Processing</StatusBarItem>
				</StatusBar>
				<DockPanel DockPanel.Dock="Bottom">
					<TextBlock Padding="5">Work Directory: </TextBlock>
					<TextBox Padding="5" Name="XamlWorkDir" TextChanged="XamlWorkDir_TextChanged"></TextBox>
				</DockPanel>
				<icsa:TextEditor Name="CodeEditor" 
                                 SyntaxHighlighting="XML" 
                                 ShowLineNumbers="True" 
                                 FontFamily="{DynamicResource FontFamilyForCoding}"
								 TextChanged="CodeEditor_TextChanged"/>
			</DockPanel>
			<GridSplitter Grid.Column="1" 
                          Width="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Background="Gray"
                          ResizeBehavior="PreviousAndNext"/>
			<Grid Grid.Column="2">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0" Margin="5">Controls:</TextBlock>
				<TreeView Grid.Row="1" x:Name="ControlTreeList" SelectedItemChanged="ControlTreeList_SelectedItemChanged">
					<TreeView.ItemTemplate>
						<HierarchicalDataTemplate ItemsSource="{Binding Controls}">
							<TextBlock Text="{Binding Namespace}" FontWeight="Bold" />
							<HierarchicalDataTemplate.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Name}" />
								</DataTemplate>
							</HierarchicalDataTemplate.ItemTemplate>
						</HierarchicalDataTemplate>
					</TreeView.ItemTemplate>
				</TreeView>
				<GridSplitter Grid.Row="2" 
                  Height="5" 
                  HorizontalAlignment="Stretch" 
                  VerticalAlignment="Center" 
                  Background="Gray"
                  ResizeBehavior="PreviousAndNext" 
                  ResizeDirection="Rows" />
				<icsa:TextEditor Grid.Row="3" 
                     Name="XamlDisplay" 
                     SyntaxHighlighting="XML" 
                     ShowLineNumbers="True" 
					IsReadOnly="True"
                     FontFamily="{DynamicResource FontFamilyForCoding}" />
				<StatusBar Grid.Row="4">
					<StatusBarItem Name="CurrSelectedItem">Current Selected:</StatusBarItem>
				</StatusBar>
			</Grid>
			<GridSplitter Grid.Column="3" 
                          Width="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Background="Gray"
                          ResizeBehavior="PreviousAndNext"/>
			<Grid Grid.Column="4" Name="WpfControlContainer">
				<DockPanel>
					<Grid DockPanel.Dock="Top" Margin="5,2">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<WrapPanel Grid.Column="0" VerticalAlignment="Center">
							<CheckBox x:Name="SidebarPreviewCheckBox" 
							  Margin="5,5,5,0" 
							  VerticalAlignment="Center"
							  Content="Left Sidebar Preview"
							Checked="SidebarPreviewCheckBox_Checked"
									  Unchecked="SidebarPreviewCheckBox_Unchecked"/>
							<TextBlock Margin="5" VerticalAlignment="Center">Background:</TextBlock>
							<ComboBox x:Name="BackgroundColorCombo" 
									  Margin="5,0,0,0"
							  Width="100" 
							  VerticalAlignment="Center"
							  SelectionChanged="BackgroundColorCombo_SelectionChanged" />
							<TextBlock Margin="5" VerticalAlignment="Center">Preview:</TextBlock>
						</WrapPanel>
						<Button Grid.Column="1" 
							Name="PreviewButton"
							Width="Auto" Height="Auto" 
							Padding="10,2" 
							Click="PreviewButton_Click"
							VerticalAlignment="Center">Preview</Button>
					</Grid>
					<Border x:Name="PreviewClipBorder" 
                Background="LightGray" 
                ClipToBounds="True">
						<Grid>
							<!-- 背景层：静态棋盘，不受缩放平移影响，填满 Border -->
							<Border x:Name="BackgroundLayer" 
                        Background="{StaticResource ChessboardBrush}" />

							<!-- 内容层：应用缩放和平移变换 -->
							<Grid x:Name="PreviewContainer"
                      RenderTransformOrigin="0,0">
								<Grid.RenderTransform>
									<TransformGroup>
										<ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
										<TranslateTransform x:Name="PanTransform"/>
									</TransformGroup>
								</Grid.RenderTransform>
								<Canvas x:Name="DesignCanvas" 
									Background="Transparent" 
									Margin="20" />
								<Border x:Name="SidebarOverlay" 
									Background="#80FFFFFF" 
									BorderBrush="Black" 
									BorderThickness="1,0,0,0"
									Width="150" 
									HorizontalAlignment="Left" 
									Visibility="Collapsed" />
							</Grid>
						</Grid>
					</Border>
				</DockPanel>
			</Grid>
		</Grid>
	</Grid>
</Window>