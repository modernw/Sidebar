<UserControl x:Class="ThemeEditor.Tiles.Power.DetailButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Power"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<StackPanel Orientation="Vertical">
			<ToggleButton Width="23" Margin="5" Style="{DynamicResource TilePowerFoldToggleButton}"></ToggleButton>
			<ToggleButton Width="23"  Margin="5" Style="{DynamicResource TilePowerFoldToggleButton}" IsChecked="True"></ToggleButton>
		</StackPanel>
    </Grid>
</UserControl>
