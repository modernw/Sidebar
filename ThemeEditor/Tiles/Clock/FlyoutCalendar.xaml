<UserControl x:Class="ThemeEditor.Tiles.Clock.FlyoutCalendar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Clock"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid>
		<Viewbox>
			<Border Style="{DynamicResource TileClockCalendarBorder}">
				<DockPanel Style="{DynamicResource TileClockCalendarContainer}">
					<Image Name="MonthImage" RenderOptions.BitmapScalingMode="HighQuality" Style="{DynamicResource TileClockCalendarMonthImage}">
					</Image>
					<Grid>
						<Calendar Name="MonthCalendar" Style="{DynamicResource TileClockCalendarItem}">
						</Calendar>
					</Grid>
				</DockPanel>
			</Border>
		</Viewbox>
	</Grid>
</UserControl>
