<UserControl x:Class="ThemeEditor.Tiles.Clock.Others"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Clock"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid>
		<StackPanel Orientation="Vertical" Margin="5">
			<Button Margin="5" Style="{DynamicResource TileClockCalendarBackButton}"></Button>
			<Button Margin="5" Style="{DynamicResource TileClockCalendarNextButton}"></Button>
			<Button Margin="5" Width="13" Height="13" Style="{DynamicResource TileClockFlyoutAlarmPointAM}"></Button>
			<Button Margin="5" Width="13" Height="13" Style="{DynamicResource TileClockFlyoutAlarmPointPM}"></Button>
		</StackPanel>  
    </Grid>
</UserControl>
