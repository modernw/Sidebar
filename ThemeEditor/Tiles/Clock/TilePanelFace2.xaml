<UserControl x:Class="ThemeEditor.Tiles.Clock.TilePanelFace2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Clock"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Style="{DynamicResource TileClockPanelFace2}">
		<StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
				<local:ClockFace x:Name="ClockCtrl" Style="{DynamicResource TileClockPanel2Clock}"></local:ClockFace>
				<Grid Height="1" Width="5"></Grid>
				<local:TileDay x:Name="ClockSmallCalendar" Style="{DynamicResource TileClockPanelSmallCalendar}"></local:TileDay>
			</StackPanel>
			<local:TileShortTime x:Name="ClockShortTime" HorizontalAlignment="Center" DockPanel.Dock="Bottom" Style="{DynamicResource TileClockPanelShortTimeText2}"></local:TileShortTime>
		</StackPanel>
	</Grid>
</UserControl>
