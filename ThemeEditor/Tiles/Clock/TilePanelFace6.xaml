<UserControl x:Class="ThemeEditor.Tiles.Clock.TilePanelFace6"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Clock"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Style="{DynamicResource TileClockPanelFace6}">
		<DockPanel LastChildFill="True">
			<local:ClockFace x:Name="ClockPart" Style="{DynamicResource TileClockPanelClock6}"></local:ClockFace>
			<StackPanel Style="{DynamicResource TileClockPanelTextPart5}">
				<local:TileShortTime x:Name="ShortTime" Style="{DynamicResource TileClockPanelShortTimeText6}"></local:TileShortTime>
				<TextBlock Name="Date" Style="{DynamicResource TileClockPanelCommonTextLeft}">May 11</TextBlock>
			</StackPanel>
		</DockPanel>
	</Grid>
</UserControl>
