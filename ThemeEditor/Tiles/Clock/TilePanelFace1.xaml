<UserControl x:Class="ThemeEditor.Tiles.Clock.TilePanelFace1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Clock"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Style="{DynamicResource TileClockPanelFace1}">
		<DockPanel>
			<Grid Height="2" DockPanel.Dock="Top"></Grid>
			<TextBlock Name="ClockDateTime" DockPanel.Dock="Bottom" Style="{DynamicResource TileClockPanelCommonText}">11:58 PM, Apr 24</TextBlock>
			<local:ClockFace x:Name="ClockCtrl"></local:ClockFace>
		</DockPanel>
	</Grid>
</UserControl>
