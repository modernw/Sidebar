<UserControl x:Class="ThemeEditor.Tiles.Feeds.FlyoutFeedItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Feeds"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Margin="0,10,0,10">
		<WrapPanel Orientation="Vertical" Name="FeedItemContainer" MouseEnter="FeedItemContainer_MouseEnter" MouseLeave="FeedItemContainer_MouseLeave" MouseDown="FeedItemContainer_MouseDown" MouseUp="FeedItemContainer_MouseUp" TouchDown="FeedItemContainer_TouchDown" TouchUp="FeedItemContainer_TouchUp">
			<TextBlock Name="Title" Style="{DynamicResource TileFeedItemTitle}">Feed Item Title Feed Item Title Feed Item Title Feed Item Title</TextBlock>
			<TextBlock Name="Desc" Style="{DynamicResource TileFeedItemDescription}">Feed Item Content Feed Item Content Feed Item Content Feed Item Content Feed Item Content Feed Item Content Feed Item Content</TextBlock>
		</WrapPanel>
	</Grid>
</UserControl>
