<UserControl x:Class="ThemeEditor.Tiles.Feeds.TilePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Feeds"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Margin="7,0,7,0" Height="Auto">
		<Grid>
			<StackPanel Orientation="Vertical" Name="FeedItemsContainerBehind" VerticalAlignment="Top">
				<local:TileFeedItem></local:TileFeedItem>
				<local:TileFeedItem></local:TileFeedItem>
				<local:TileFeedItem></local:TileFeedItem>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
