<UserControl x:Class="ThemeEditor.Tiles.Feeds.TileFeedItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Feeds"
             mc:Ignorable="d" SizeChanged="UserControl_SizeChanged"
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid Margin="0,15,0,15">
		<StackPanel Orientation="Horizontal" VerticalAlignment="Top" MouseEnter="StackPanel_MouseEnter" MouseLeave="StackPanel_MouseLeave" Background="Transparent" MouseLeftButtonDown="StackPanel_MouseLeftButtonDown" MouseLeftButtonUp="StackPanel_MouseLeftButtonUp" TouchDown="StackPanel_TouchDown" TouchUp="StackPanel_TouchUp">
			<DockPanel Margin="5,1,0,0">
				<Image DockPanel.Dock="Top" Name="ItemPoint" Style="{DynamicResource TileFeedsTileItemPoint}" Stretch="None"></Image>
				<Grid></Grid>
			</DockPanel>
			<TextBlock Name="FeedTitle" Margin="4,0,0,0" TextWrapping="Wrap" Style="{DynamicResource TileFeedTitleNormal}">Feed Item Title Feed Item Title</TextBlock>
		</StackPanel>
	</Grid>
</UserControl>
