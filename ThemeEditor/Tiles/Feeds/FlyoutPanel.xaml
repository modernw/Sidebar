<UserControl x:Class="ThemeEditor.Tiles.Feeds.FlyoutPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Feeds"
			 xmlns:sib="clr-namespace:ThemeEditor.Sidebar"
             mc:Ignorable="d" Width="378" Height="721"
             d:DesignHeight="300" d:DesignWidth="300">
	<Grid>
		<Grid Name="BackgroundPart">
			<Rectangle Name="FlyoutBackgroundBlur" Fill="Transparent" IsHitTestVisible="False" SnapsToDevicePixels="True"></Rectangle>
			<Rectangle Name="FlyoutBackgroundFill" Style="{DynamicResource FlyoutBackgroundFill}"></Rectangle>
			<Rectangle Name="FlyoutBorderBehind" Style="{DynamicResource FlyoutBorderBehind}"></Rectangle>
			<Image Name="FlyoutBackgroundImage" Style="{DynamicResource FlyoutBackgroundImage}"></Image>
			<Rectangle Name="FlyoutBorder" Style="{DynamicResource FlyoutBorder}"></Rectangle>
			<Rectangle Name="FlyoutBorder1" Style="{DynamicResource FlyoutBorder1}"></Rectangle>
			<Rectangle Name="FlyoutBackgroundHighlight" Style="{DynamicResource FlyoutBackgroundHighlight}"></Rectangle>
			<Rectangle Name="FlyoutBackgroundHighlight1" Style="{DynamicResource FlyoutBackgroundHighlight1}"></Rectangle>
		</Grid>
		<Grid Name="ForegroundPart">
			<Grid Name="FlyoutContent" Style="{DynamicResource FlyoutContent}">
				<!-- Flyout Part Begin-->
				<Grid>
					<DockPanel Width="370">
						<Grid DockPanel.Dock="Top" Height="52">
							<Rectangle Style="{DynamicResource TileFeedFlyoutHeaderBackground}"></Rectangle>
							<TextBlock Name="FeedTitle" TextTrimming="CharacterEllipsis" Style="{DynamicResource TileFeedFlyoutHeaderTitle}">Feed Title</TextBlock>
							<Button Name="ButtonBack" Focusable="False" HorizontalAlignment="Left" Style="{DynamicResource TileFeedFlyoutSwitchButton}">3</Button>
							<Button Name="ButtonNext" Focusable="False" HorizontalAlignment="Right" Style="{DynamicResource TileFeedFlyoutSwitchButton}">4</Button>
						</Grid>
						<Line DockPanel.Dock="Top" Style="{DynamicResource TileFeedFlyoutLine}"></Line>
						<ScrollViewer Style="{DynamicResource TileFeedFlyoutContentPart}" VerticalScrollBarVisibility="Auto">
							<WrapPanel Style="{DynamicResource TileFeedFlyoutContentContainer}" Name="FeedItemList">
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
								<local:FlyoutFeedItem></local:FlyoutFeedItem>
							</WrapPanel>
						</ScrollViewer>
					</DockPanel>
				</Grid>
				<!-- Flyout Part End -->
			</Grid>
			<sib:TopOptions x:Name="FlyoutHeader" Style="{DynamicResource FlyoutHeaderOptionsBar}" VerticalAlignment="Top" IconStyle="{DynamicResource FlyoutHeaderOptionsIcon}">
			</sib:TopOptions>
		</Grid>
	</Grid>
</UserControl>
