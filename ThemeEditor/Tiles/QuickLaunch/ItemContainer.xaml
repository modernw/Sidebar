<UserControl x:Class="ThemeEditor.Tiles.QuickLaunch.ItemContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.QuickLaunch"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<Border BorderBrush="DarkCyan" BorderThickness="1" Height="40">
			<ItemsControl Background="Bisque" Style="{DynamicResource TileIconItemTileContainerForQuickLaunchTile}"></ItemsControl>
		</Border>
    </Grid>
</UserControl>
