<UserControl x:Class="ThemeEditor.Tiles.QuickLaunch.TileItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.QuickLaunch"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<ToggleButton Margin="5" Style="{DynamicResource TileIconItemForQuickLaunchTile}">
			<Image Width="16" Height="16" Style="{DynamicResource PreviewIconStyle}"></Image>
		</ToggleButton>
	</Grid>
</UserControl>
