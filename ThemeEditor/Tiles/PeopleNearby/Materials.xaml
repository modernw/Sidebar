<UserControl x:Class="ThemeEditor.Tiles.PeopleNearby.Materials"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.PeopleNearby"
             mc:Ignorable="d" Height="Auto"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
			<Image Stretch="None" Margin="5" Style="{DynamicResource TileNotificationRingNormal}"></Image>
			<Image Stretch="None" Margin="5" Style="{DynamicResource TileNotificationRingAbnormal}"></Image>
			<Image Stretch="None" Margin="5" Style="{DynamicResource TileNotificationMessage}"></Image>
			<Image Stretch="None" Margin="5" Style="{DynamicResource TileNotificationMessage2}"></Image>
			<Image Stretch="None" Margin="5" Style="{DynamicResource TileNotificationMessage3}"></Image>
			<Image Stretch="None" Margin="5" Style="{DynamicResource TileNotificationMessage4}"></Image>
		</StackPanel>
    </Grid>
</UserControl>
