<UserControl x:Class="ThemeEditor.Tiles.Common.IconItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Common"
             mc:Ignorable="d" Height="200"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<StackPanel Orientation="Vertical">
			<ToggleButton Margin="5" Style="{DynamicResource TileIconItemButtonStyle}">
				<Image Width="16" Height="16" Style="{DynamicResource PreviewIconStyle}"></Image>
			</ToggleButton>
			<Border Width="24" Height="24" Margin="5" BorderBrush="{DynamicResource TileIconItemHoverBorderBrush}" Background="{DynamicResource TileIconItemHoverBackground}">
				<Image Width="16" Height="16" Style="{DynamicResource PreviewIconStyle}"></Image>
			</Border>
			<Border Width="24" Height="24" Margin="5" BorderBrush="{DynamicResource TileIconItemPressedBorderBrush}" Background="{DynamicResource TileIconItemPressedBackground}">
				<Image Width="16" Height="16" Style="{DynamicResource PreviewIconStyle}"></Image>
			</Border>
			<Border Width="24" Height="24" Margin="5" BorderBrush="{DynamicResource TileIconItemHoverBorderBrush}" Background="{DynamicResource TileIconItemHoverBackground}">
				
			</Border>
			<Border Width="24" Height="24" Margin="5" BorderBrush="{DynamicResource TileIconItemPressedBorderBrush}" Background="{DynamicResource TileIconItemPressedBackground}">
				
			</Border>
		</StackPanel>
    </Grid>
</UserControl>
