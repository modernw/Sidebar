<UserControl x:Class="ThemeEditor.Tiles.Others.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Tiles.Others"
			 xmlns:snt="clr-namespace:Sidebar;assembly=Native"
             mc:Ignorable="d" Width="Auto" Height="250"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
			<snt:Slice9Image Width="80" Height="40" Margin="5" Style="{DynamicResource PreviewTileOrangeHoverImage}"></snt:Slice9Image>
			<snt:Slice9Button Width="80" Height="32" Margin="5" UseAnimation="True" ExclusiveStateDisplay="True" Style="{DynamicResource PreviewTileOrangeItem}" Child="Button"></snt:Slice9Button>
			<snt:Slice9Image Width="80" Height="40" Margin="5" Style="{DynamicResource PreviewTileDarkHoverImage}"></snt:Slice9Image>
			<snt:Slice9Image Width="80" Height="40" Margin="5" Style="{DynamicResource PreviewTileDarkActiveImage}"></snt:Slice9Image>
			<snt:Slice9Button Width="80" Height="32" Margin="5" UseAnimation="True" ExclusiveStateDisplay="True" Style="{DynamicResource PreviewTileDarkItem}" Child="Button"></snt:Slice9Button>
		</StackPanel>
		
    </Grid>
</UserControl>
