<UserControl x:Class="ThemeEditor.Sidebar.DragPlaceholder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ThemeEditor.Sidebar"
			 xmlns:p="clr-namespace:ThemeEditor"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>
		<p:DirectionToScaleXConverter x:Key="DirectionToScaleX"/>
		<p:DirectionToHorizontalAlignmentConverter x:Key="DirectionToHorizontalAlignment" />
	</UserControl.Resources>
	<Grid>
		<DockPanel>
			<StackPanel Name="Splitter" Style="{DynamicResource TileSplitterPanel}" RenderTransformOrigin="0.5,0.5" DockPanel.Dock="Bottom">
				<StackPanel.RenderTransform>
					<ScaleTransform ScaleX="{Binding Source={StaticResource CurrentUserConfig}, 
                                         Path=Direction, 
                                         Converter={StaticResource DirectionToScaleX}}"/>
				</StackPanel.RenderTransform>
				<Rectangle Name="SplitterLineTopFill" IsHitTestVisible="False" Style="{DynamicResource TileSplitterTopBlankFill}"></Rectangle>
				<Line Name="SplitterLine1" Style="{DynamicResource TileSplitterLineTop}"/>
				<Line Name="SplitterLine2" Style="{DynamicResource TileSplitterLineBottom}"/>
				<Rectangle Name="SplitterLineBottomFill" IsHitTestVisible="False" Style="{DynamicResource TileSplitterBottomBlankFill}"></Rectangle>
			</StackPanel>
			<Rectangle Style="{DynamicResource DragPlaceholder}"></Rectangle>
		</DockPanel>
	</Grid>
</UserControl>
