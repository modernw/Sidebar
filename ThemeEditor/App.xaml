					<Style x:Key="SidebarOverflowTileItem" TargetType="ToggleButton" BasedOn="{StaticResource TileIconItemButtonStyle}">
					</Style>
					<ItemsPanelTemplate x:Key="SidebarOverflowTileItemWrapPanel">
						<WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"/>
					</ItemsPanelTemplate>
					<Style x:Key="SidebarOverflowTileItemControlContainer" TargetType="ItemsControl" BasedOn="{StaticResource TileIconItemTileContainer}"></Style>

					<!-- For Preview -->
					<Style x:Key="PreviewIconStyle" TargetType="Image">
						<Setter Property="Source" Value="Images\default.ico"></Setter>
					</Style>
					<Style x:Key="PreviewTileOrangeHoverImage" TargetType="snt:Slice9Image">
						<Setter Property="Source" Value="{DynamicResource TileItemHoverImage}"></Setter>
						<Setter Property="SliceThickness" Value="4"></Setter>
					</Style>
					<Style x:Key="PreviewTileOrangeItem" TargetType="snt:Slice9Button">
						<Setter Property="HoverSource" Value="{DynamicResource TileItemHoverImage}"></Setter>
						<Setter Property="HoverSliceThickness" Value="4"></Setter>
					</Style>
					<Style x:Key="PreviewTileDarkHoverImage" TargetType="snt:Slice9Image">
						<Setter Property="Source" Value="{DynamicResource TileIconItemHoverImage}"></Setter>
						<Setter Property="SliceThickness" Value="4"></Setter>
					</Style>
					<Style x:Key="PreviewTileDarkActiveImage" TargetType="snt:Slice9Image">
						<Setter Property="Source" Value="{DynamicResource TileIconItemActiveImage}"></Setter>
						<Setter Property="SliceThickness" Value="4"></Setter>
					</Style>
					<Style x:Key="PreviewTileDarkItem" TargetType="snt:Slice9Button">
						<Setter Property="HoverSource" Value="{DynamicResource TileIconItemHoverImage}"></Setter>
						<Setter Property="HoverSliceThickness" Value="4"></Setter>
						<Setter Property="ActiveSource" Value="{DynamicResource TileIconItemActiveImage}"></Setter>
						<Setter Property="ActiveSliceThickness" Value="4"></Setter>
					</Style>
				</ResourceDictionary>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>
</Application>
