<Application x:Class="ThemeEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ThemeEditor" 
			 xmlns:l_s="clr-namespace:ThemeEditor.Sidebar"
			 xmlns:sys="clr-namespace:System;assembly=mscorlib"
			 xmlns:snt="clr-namespace:Sidebar;assembly=Native"
			 Startup="Application_Startup"
             StartupUri="MainWindow.xaml">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary>
					<!--  Options  -->
					<sys:Boolean x:Key="EnableBlur">True</sys:Boolean>
					<sys:Boolean x:Key="EnableBlurForFlyout">false</sys:Boolean>
					<sys:Boolean x:Key="EnableBlurForDrag">false</sys:Boolean>
					<!--  Global Fonts  -->
					<FontFamily x:Key="GlobalFontFamily">
						Microsoft YaHei, Segoe UI, Ebrima, Nirmala, Gadugi, Segoe UI Emoji, Segoe UI Symbol,
						Meiryo, Leelawadee, Microsoft JhengHei, Malgun Gothic, Estrangelo Edessa, Microsoft Himalaya,
						Microsoft New Tai Lue, Microsoft PhagsPa, Microsoft Tai Le, Microsoft Yi Baiti, Mongolian Baiti,
						MV Boli, Myanmar Text, Javanese Text, Cambria Math
					</FontFamily>
					<FontFamily x:Key="FontFamilyForCoding">
						Consolas, Courier New, Lucida Console, Source Code Pro, 
						Hack, Cascadia Code, Fira Code, JetBrains Mono, Maple Mono, 
						DejaVu Sans Mono, Liberation Mono, Ubuntu Mono,
						
						Microsoft YaHei, Segoe UI, Ebrima, Nirmala, Gadugi, Segoe UI Emoji, Segoe UI Symbol,
						Meiryo, Leelawadee, Microsoft JhengHei, Malgun Gothic, Estrangelo Edessa, Microsoft Himalaya,
						Microsoft New Tai Lue, Microsoft PhagsPa, Microsoft Tai Le, Microsoft Yi Baiti, Mongolian Baiti,
						MV Boli, Myanmar Text, Javanese Text, Cambria Math
					</FontFamily>
					<!-- Global -->
					<SolidColorBrush x:Key="GlobalForegroundBrush" Color="{Binding ForegroundColor, Source={x:Static local:DwmThemeProvider.Instance}}" />
					<sys:Double x:Key="GlobalFontSize">10</sys:Double>
					<sys:Double x:Key="GlobalNormalFontSize">10</sys:Double>
					<sys:Double x:Key="GlobalNormalFontSizeSmall">9</sys:Double>
					<Style x:Key="GlobalControlTextDisplay" TargetType="Control">
						<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
						<Setter Property="Foreground" Value="{DynamicResource GlobalForegroundBrush}" />
						<Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}" />
					</Style>
					<Style x:Key="GlobalTextBlockTextDisplay" TargetType="TextBlock">
						<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
						<Setter Property="Foreground" Value="{DynamicResource GlobalForegroundBrush}" />
						<Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}" />
					</Style>
					<!--  Sidebar  -->
					<Style x:Key="Background" TargetType="Rectangle">
						<Setter Property="HorizontalAlignment" Value="Stretch" />
						<Setter Property="VerticalAlignment" Value="Stretch" />
						<Setter Property="Fill" Value="{Binding ThemeBrush, Source={x:Static local:DwmThemeProvider.Instance}}" />
					</Style>
					<Style x:Key="BackgroundImage" TargetType="Image">
						<Setter Property="HorizontalAlignment" Value="Stretch" />
						<Setter Property="VerticalAlignment" Value="Stretch" />
						<Setter Property="Stretch" Value="Fill" />
						<Setter Property="Source" Value="{x:Null}" />
					</Style>
					<Style x:Key="BackgroundHighlight" TargetType="Rectangle">
						<Setter Property="HorizontalAlignment" Value="Stretch" />
						<Setter Property="VerticalAlignment" Value="Stretch" />
						<Setter Property="Fill" Value="Transparent" />
					</Style>
					<Style x:Key="BorderLine" TargetType="Line">
						<Setter Property="Stroke" Value="#53000000" />
						<Setter Property="StrokeThickness" Value="1"></Setter>
					</Style>
					<Style x:Key="BackgroundCustomDraw" TargetType="Canvas">
						<Setter Property="Visibility" Value="Collapsed" />
						<Setter Property="HorizontalAlignment" Value="Stretch" />
						<Setter Property="VerticalAlignment" Value="Stretch" />
					</Style>
					<Style x:Key="TileSplitterPanel" TargetType="StackPanel">
						<Setter Property="DockPanel.Dock" Value="Bottom" />
						<Setter Property="Height" Value="4" />
						<Setter Property="Cursor" Value="SizeNS" />
						<Setter Property="Background" Value="#00000000" />
					</Style>
					<Style x:Key="TileSplitterLineTop" TargetType="Line">
						<Setter Property="Opacity" Value="0" />
					</Style>
					<Style x:Key="TileSplitterLineBottom" TargetType="Line">
						<Setter Property="Opacity" Value="1" />
						<Setter Property="X1" Value="0" />
						<Setter Property="X2" Value="200" />
						<Setter Property="Stretch" Value="UniformToFill" />
						<Setter Property="StrokeThickness" Value="1" />
						<Setter Property="Stroke" Value="#53000000" />
					</Style>
					<Style x:Key="TileSplitterTopBlankFill" TargetType="Rectangle">
						<Setter Property="Height" Value="0"></Setter>
					</Style>
					<Style x:Key="TileSplitterBottomBlankFill" TargetType="Rectangle">
						<Setter Property="Height" Value="0"></Setter>
					</Style>
					<Style x:Key="TileSplitterLineTopLighting" TargetType="Line">
						<Setter Property="Opacity" Value="0" />
					</Style>
					<Style x:Key="TileSplitterLineBottomLighting" TargetType="Line">
						<Setter Property="Opacity" Value="1" />
						<Setter Property="X1" Value="0" />
						<Setter Property="X2" Value="200" />
						<Setter Property="Stretch" Value="UniformToFill" />
						<Setter Property="StrokeThickness" Value="1" />
						<Setter Property="Stroke" Value="#53FFFFFF" />
					</Style>
					<Style x:Key="TileSplitterTopBlankFillLighting" TargetType="Rectangle" BasedOn="{StaticResource TileSplitterTopBlankFill}">
					</Style>
					<Style x:Key="TileSplitterBottomBlankFillLighting" TargetType="Rectangle" BasedOn="{StaticResource TileSplitterBottomBlankFill}">
					</Style>
					<Style x:Key="TopOptionsPanel" TargetType="FrameworkElement">
						<Setter Property="VerticalAlignment" Value="Top" />
						<Setter Property="Height" Value="17" />
					</Style>
					<Style x:Key="TopOptionsPanelSplitter" TargetType="StackPanel">
						<Setter Property="Margin" Value="0,17,0,0" />
						<Setter Property="VerticalAlignment" Value="Top" />
						<Setter Property="Cursor" Value="Arrow" />
						<Setter Property="Background" Value="#00000000" />
						<Setter Property="Height" Value="4" />
					</Style>
					<Style x:Key="MainPanel" TargetType="DockPanel">
						<Setter Property="Margin" Value="0,19,0,0" />
						<Setter Property="HorizontalAlignment" Value="Stretch" />
						<Setter Property="VerticalAlignment" Value="Stretch" />
						<Setter Property="LastChildFill" Value="True" />
					</Style>
					<Style x:Key="PinnedTilesRegion" TargetType="StackPanel">
						<Setter Property="DockPanel.Dock" Value="Bottom" />
						<Setter Property="HorizontalAlignment" Value="Stretch" />
						<Setter Property="VerticalAlignment" Value="Top" />
					</Style>
					<Style x:Key="TilesRegion" TargetType="StackPanel">
						<Setter Property="HorizontalAlignment" Value="Stretch" />
						<Setter Property="VerticalAlignment" Value="Stretch" />
					</Style>
					<Style x:Key="SidebarHighlight" TargetType="Rectangle">
						<Setter Property="Stretch" Value="Fill" />
						<Setter Property="HorizontalAlignment" Value="Left" />
						<Setter Property="Width" Value="8" />
						<Setter Property="Visibility" Value="Hidden" />
					</Style>
					<Style x:Key="BackgroundImageSlice9" TargetType="snt:Slice9Image">
						<Setter Property="Visibility" Value="Collapsed"></Setter>
					</Style>
					<!--  Top Options  -->
					<Style x:Key="TopOptionsText" TargetType="TextBlock">
						<Setter Property="Foreground" Value="{DynamicResource GlobalForegroundBrush}"/>
						<Setter Property="FontSize" Value="{DynamicResource GlobalNormalFontSize}"/>
						<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
					</Style>
					<Style x:Key="TopOptionsIcon" TargetType="Polygon">
						<Setter Property="Opacity" Value="0.45" />
						<Setter Property="Stroke" Value="#020202" />
						<Setter Property="StrokeThickness" Value="1" />
						<Setter Property="Fill" Value="White" />
						<Setter Property="Margin" Value="2,1,2,0" />
						<Setter Property="RenderTransformOrigin" Value="0.556,0.9" />
						<Setter Property="SnapsToDevicePixels" Value="True" />
						<Setter Property="UseLayoutRounding" Value="True" />
						<Setter Property="StrokeStartLineCap" Value="Round" />
						<Setter Property="StrokeEndLineCap" Value="Round" />
						<Setter Property="StrokeLineJoin" Value="Round" />
					</Style>
					<!--  Tile  -->
					<Style x:Key="TilePanel" TargetType="DockPanel">
						<Setter Property="Background" Value="#00000000" />
					</Style>
					<Style x:Key="TileHeader" TargetType="DockPanel">
						<Setter Property="Visibility" Value="Visible" />
						<Setter Property="DockPanel.Dock" Value="Top" />
						<Setter Property="Height" Value="20" />
						<Setter Property="Background" Value="#00000000" />
					</Style>
					<Style x:Key="TileIcon" TargetType="Image">
						<Setter Property="DockPanel.Dock" Value="Right" />
						<Setter Property="Height" Value="15" />
						<Setter Property="Width" Value="15" />
						<Setter Property="Source" Value="Images\default.ico" />
					</Style>
					<Style x:Key="TileTitle" TargetType="TextBlock">
						<Setter Property="VerticalAlignment" Value="Center" />
						<Setter Property="HorizontalAlignment" Value="Left" />
						<Setter Property="Margin" Value="5,0,5,0" />
						<Setter Property="FontSize" Value="10" />
						<Setter Property="Foreground" Value="{DynamicResource GlobalForegroundBrush}"/>
						<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
					</Style>
					<Style x:Key="TileContent" TargetType="Grid">
						<Setter Property="Background" Value="#00000000" />
						<Setter Property="Margin" Value="1,0,0,0" />
					</Style>
					<Style x:Key="TileFlyoutIcon" TargetType="Polygon">
						<Setter Property="Opacity" Value="0" />
						<Setter Property="Stroke" Value="#020202" />
						<Setter Property="StrokeThickness" Value="1" />
						<Setter Property="Fill" Value="White" />
						<Setter Property="Margin" Value="1,2,1,0" />
						<Setter Property="RenderTransformOrigin" Value="0.556,0.9" />
						<Setter Property="SnapsToDevicePixels" Value="True" />
						<Setter Property="UseLayoutRounding" Value="True" />
						<Setter Property="StrokeStartLineCap" Value="Round" />
						<Setter Property="StrokeEndLineCap" Value="Round" />
						<Setter Property="StrokeLineJoin" Value="Round" />
					</Style>
					<Style x:Key="PinnedTileIcon" BasedOn="{StaticResource TileIcon}" TargetType="Image" />
					<Style
						x:Key="PinnedTileTitle"
						BasedOn="{StaticResource TileTitle}"
						TargetType="TextBlock" />
					<Style x:Key="PinnedTileHeader" TargetType="DockPanel">
						<Setter Property="Visibility" Value="Collapsed" />
					</Style>
					<Style
						x:Key="PinnedTileFlyoutIcon"
						BasedOn="{StaticResource TileFlyoutIcon}"
						TargetType="Polygon">
						<Setter Property="Margin" Value="1,4,1,0" />
					</Style>
					<Style
						x:Key="PinnedTileContent"
						BasedOn="{StaticResource TileContent}"
						TargetType="Grid">
						<!-- <Setter Property="Margin" Value="0,0,1,0" /> -->
					</Style>
					<Style
						x:Key="PinnedTileSplitterPanel"
						BasedOn="{StaticResource TileSplitterPanel}"
						TargetType="StackPanel">
						<Setter Property="DockPanel.Dock" Value="Top" />
					</Style>
					<Style x:Key="AutoHideScrollViewer" TargetType="ScrollViewer">
						<Setter Property="VerticalScrollBarVisibility" Value="Auto" />
						<Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="ScrollViewer">
									<Grid Background="{TemplateBinding Background}">
										<ScrollContentPresenter
											x:Name="PART_ScrollContentPresenter"
											Width="{TemplateBinding Width}"
											Height="{TemplateBinding Height}"
											Margin="{TemplateBinding Padding}"
											CanContentScroll="{TemplateBinding CanContentScroll}"
											Content="{TemplateBinding Content}" />
										<ScrollBar
											x:Name="PART_VerticalScrollBar"
											Width="6"
											Margin="0,0,2,2"
											HorizontalAlignment="Right"
											Maximum="{TemplateBinding ScrollableHeight}"
											Opacity="0"
											Orientation="Vertical"
											ViewportSize="{TemplateBinding ViewportHeight}"
											Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
											Value="{TemplateBinding VerticalOffset}">
											<!--  按下时立即完全不透明，松开时恢复半透明  -->
											<ScrollBar.Triggers>
												<EventTrigger RoutedEvent="Mouse.MouseDown">
													<BeginStoryboard>
														<Storyboard>
															<DoubleAnimation
																Storyboard.TargetName="PART_VerticalScrollBar"
																Storyboard.TargetProperty="Opacity"
																To="1"
																Duration="0:0:0" />
														</Storyboard>
													</BeginStoryboard>
												</EventTrigger>
												<EventTrigger RoutedEvent="Mouse.MouseUp">
													<BeginStoryboard>
														<Storyboard>
															<DoubleAnimation
																Storyboard.TargetName="PART_VerticalScrollBar"
																Storyboard.TargetProperty="Opacity"
																To="0.8"
																Duration="0:0:0" />
														</Storyboard>
													</BeginStoryboard>
												</EventTrigger>
											</ScrollBar.Triggers>
										</ScrollBar>
									</Grid>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Trigger.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation
															Storyboard.TargetName="PART_VerticalScrollBar"
															Storyboard.TargetProperty="Opacity"
															To="0.8"
															Duration="0:0:0.2" />
													</Storyboard>
												</BeginStoryboard>
											</Trigger.EnterActions>
											<Trigger.ExitActions>
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation
															Storyboard.TargetName="PART_VerticalScrollBar"
															Storyboard.TargetProperty="Opacity"
															To="0"
															Duration="0:0:0.5" />
													</Storyboard>
												</BeginStoryboard>
											</Trigger.ExitActions>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
					<!--  Flyout  -->
					<Style x:Key="FlyoutBorder" TargetType="Rectangle">
						<Setter Property="Stroke" Value="#53000000" />
						<Setter Property="StrokeThickness" Value="1" />
					</Style>
					<Style x:Key="FlyoutBackgroundFill" TargetType="Rectangle">
						<Setter Property="Fill" Value="{Binding ThemeBrush, Source={x:Static local:DwmThemeProvider.Instance}}" />
					</Style>
					<Style x:Key="FlyoutHeaderOptionsBar" TargetType="FrameworkElement">
						<Setter Property="Height" Value="12" />
						<Setter Property="Margin" Value="4,1,4,0" />
						<Setter Property="MinHeight" Value="0" />
					</Style>
					<Style
						x:Key="FlyoutHeaderOptionsIcon"
						BasedOn="{StaticResource TopOptionsIcon}"
						TargetType="Polygon">
						<Setter Property="Margin" Value="2,0,0,0" />
					</Style>
					<Style x:Key="FlyoutContent" TargetType="Grid">
						<Setter Property="Margin" Value="4,17,4,4" />
					</Style>
					<Style x:Key="FlyoutBackgroundImageSlice9" TargetType="snt:Slice9Image">
						<Setter Property="Visibility" Value="Collapsed"></Setter>
					</Style>
					<!--  Drag  -->
					<Style x:Key="DragWindowStyle" TargetType="FrameworkElement">
						<Setter Property="Opacity" Value="0.8" />
					</Style>
					<Style x:Key="DragPlaceholder" TargetType="Rectangle">
						<Setter Property="Margin" Value="0,0,0,0" />
						<Setter Property="Stroke" Value="#59FFFFFF" />
						<Setter Property="StrokeThickness" Value="2" />
						<Setter Property="Opacity" Value="1" />
						<Setter Property="Fill" Value="#33FFFFFF" />
						<Setter Property="RenderTransform">
							<Setter.Value>
								<ScaleTransform ScaleX="1" ScaleY="1" />
							</Setter.Value>
						</Setter>
						<Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
						<Style.Triggers>
							<EventTrigger RoutedEvent="Rectangle.Loaded">
								<BeginStoryboard>
									<Storyboard Duration="0:0:0.2">
										<DoubleAnimation
											Storyboard.TargetProperty="Opacity"
											From="1"
											To="0.6" />
										<DoubleAnimation
											Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
											From="1"
											To="0.4" />
										<DoubleAnimation
											Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
											From="1"
											To="0.4" />
									</Storyboard>
								</BeginStoryboard>
							</EventTrigger>
						</Style.Triggers>
					</Style>
					<!-- Tiles -->
					<!-- Clock -->
					<!-- Clock:FlyoutCalendar -->
					<Style x:Key="TileClockCalendarBorder" TargetType="Border">
						<Setter Property="BorderThickness" Value="1"></Setter>
						<Setter Property="Width" Value="219"></Setter>
						<Setter Property="Height" Value="294"></Setter>
						<Setter Property="BorderBrush" Value="Black"></Setter>
						<Setter Property="CornerRadius" Value="3,3,3,3"></Setter>
						<Setter Property="Background" Value="White"></Setter>
						<Setter Property="ClipToBounds" Value="True"></Setter>
						<Setter Property="Clip">
							<Setter.Value>
								<RectangleGeometry RadiusX="4" RadiusY="4" Rect="0,0,219,294"/>
							</Setter.Value>
						</Setter>
					</Style>
					<Style x:Key="TileClockCalendarContainer" TargetType="DockPanel">
					</Style>
					<Style x:Key="TileClockCalendarMonthImage" TargetType="Image">
						<Setter Property="Height" Value="113"></Setter>
						<Setter Property="DockPanel.Dock" Value="Top"></Setter>
						<Setter Property="HorizontalAlignment" Value="Center"></Setter>
						<Setter Property="Stretch" Value="UniformToFill"></Setter>
						<Setter Property="Source" Value="Images\Clock\ExampleImage.png"></Setter>
					</Style>
					<Style x:Key="TileClockCalendarItem" TargetType="Calendar">
						<Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
						<Setter Property="VerticalAlignment" Value="Stretch"></Setter>
						<Setter Property="BorderThickness" Value="0"></Setter>
					</Style>
					<Style x:Key="TileClockCalendarCalendarItem" TargetType="CalendarItem">
						<Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
						<Setter Property="VerticalAlignment" Value="Stretch"></Setter>
					</Style>
					<Style x:Key="TileClockCalendarBackButton" TargetType="Button">
						<Setter Property="Width" Value="25"/>
						<Setter Property="Height" Value="25"/>
						<Setter Property="Cursor" Value="Hand"/>
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="BorderThickness" Value="0"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Grid>
										<Image x:Name="ButtonImage" Stretch="Uniform"/>
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Grid>
									<ControlTemplate.Triggers>
										<!-- 正常状态（默认） -->
										<Trigger Property="IsMouseOver" Value="False">
											<Setter TargetName="ButtonImage" Property="Source" Value="Images\Clock\BackNormal.png"/>
										</Trigger>
										<!-- 鼠标悬停 -->
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="ButtonImage" Property="Source" Value="Images\Clock\BackLight.png"/>
										</Trigger>
										<!-- 按下状态 -->
										<Trigger Property="IsPressed" Value="True">
											<Setter TargetName="ButtonImage" Property="Source" Value="Images\Clock\BackPress.png"/>
										</Trigger>
										<!-- 禁用状态 -->
										<Trigger Property="IsEnabled" Value="False">
											<Setter Property="Opacity" Value="0.5"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
					<Style x:Key="TileClockCalendarNextButton" TargetType="Button">
						<Setter Property="Width" Value="25"/>
						<Setter Property="Height" Value="25"/>
						<Setter Property="Cursor" Value="Hand"/>
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="BorderThickness" Value="0"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Grid>
										<Image x:Name="ButtonImage" Stretch="Uniform"/>
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Grid>
									<ControlTemplate.Triggers>
										<!-- 正常状态（默认） -->
										<Trigger Property="IsMouseOver" Value="False">
											<Setter TargetName="ButtonImage" Property="Source" Value="Images\Clock\NextNormal.png"/>
										</Trigger>
										<!-- 鼠标悬停 -->
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="ButtonImage" Property="Source" Value="Images\Clock\NextLight.png"/>
										</Trigger>
										<!-- 按下状态 -->
										<Trigger Property="IsPressed" Value="True">
											<Setter TargetName="ButtonImage" Property="Source" Value="Images\Clock\NextPress.png"/>
										</Trigger>
										<!-- 禁用状态 -->
										<Trigger Property="IsEnabled" Value="False">
											<Setter Property="Opacity" Value="0.5"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
					<!-- Clock:FlyoutPanel -->
					<Style x:Key="TileClockFlyoutPanel" TargetType="Grid">
						<Setter Property="Margin" Value="0,0,4,0"></Setter>
					</Style>
					<Style x:Key="TileClockFlyoutClock" TargetType="FrameworkElement">
						<Setter Property="Width" Value="260"></Setter>
						<Setter Property="Height" Value="260"></Setter>
					</Style>
					<Style x:Key="TileClockPanelShortTimeText" TargetType="FrameworkElement">
						<Setter Property="Margin" Value="0,0,0,2"></Setter>
						<Setter Property="HorizontalAlignment" Value="Center"></Setter>
					</Style>
					<Style x:Key="TileClockPanelCommonTextFlyout" TargetType="TextBlock">
						<Setter Property="Foreground" Value="{DynamicResource GlobalForegroundBrush}"/>
						<Setter Property="FontSize" Value="{DynamicResource GlobalNormalFontSize}"/>
						<Setter Property="TextAlignment" Value="Center"></Setter>
						<Setter Property="Margin" Value="0,0,0,2"></Setter>
						<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
					</Style>
					<Style x:Key="TileClockFlyoutCalendar" TargetType="FrameworkElement">
						<Setter Property="Width" Value="219"></Setter>
						<Setter Property="Height" Value="294"></Setter>
					</Style>
					<Style x:Key="TileClockFlyoutAlarmPointAM" TargetType="Button">
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="BorderThickness" Value="0"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Grid Background="{TemplateBinding Background}">
										<Image x:Name="ButtonImage"
											Style="{DynamicResource TileClockFlyoutClockAlarmRegulator}"/>
									</Grid>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="ButtonImage" Property="Style" 
												Value="{DynamicResource TileClockFlyoutClockAlarmRegulatorHover}"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
					<Style x:Key="TileClockFlyoutAlarmPointPM" TargetType="Button">
						<Setter Property="Background" Value="Transparent"/>
						<Setter Property="BorderThickness" Value="0"/>
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Grid Background="{TemplateBinding Background}">
										<Image x:Name="ButtonImage"
											Style="{DynamicResource TileClockFlyoutClockAlarmRegulatorPm}"/>
									</Grid>
									<ControlTemplate.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter TargetName="ButtonImage" Property="Style" 
												Value="{DynamicResource TileClockFlyoutClockAlarmRegulatorPmHover}"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
