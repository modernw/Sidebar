<UserControl x:Class="WindowsModern.PowerTile.FlyoutPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.PowerTile"
             mc:Ignorable="d" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>
		<Style TargetType="{x:Type TextBlock}">
			<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
		</Style>
		<Style x:Key="TilePowerFlyoutTitle1" TargetType="TextBlock">
			<Setter Property="Foreground" Value="#989898"></Setter>
			<Setter Property="FontWeight" Value="Bold"></Setter>
			<Setter Property="FontSize" Value="12.5"></Setter>
			<Setter Property="Margin" Value="0,3,0,3"></Setter>
			<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
		</Style>
		<Style x:Key="TilePowerFlyoutTitle2" TargetType="TextBlock">
			<Setter Property="Foreground" Value="#989898"></Setter>
			<Setter Property="FontWeight" Value="Bold"></Setter>
			<Setter Property="FontSize" Value="11.25"></Setter>
			<Setter Property="Margin" Value="0,5,0,5"></Setter>
			<Setter Property="FontFamily" Value="{DynamicResource GlobalFontFamily}" />
		</Style>
		<Style x:Key="TilePowerFlyoutSpillter" TargetType="Line">
			<Setter Property="Stroke" Value="#BFBFBF"></Setter>
			<Setter Property="StrokeThickness" Value="1"></Setter>
		</Style>
	</UserControl.Resources>
    <Grid Margin="8,8,8,8">
		<StackPanel>
			<StackPanel>
				<TextBlock Name="TitlePowerStatus" Style="{DynamicResource TilePowerFlyoutTitle1}">Power Status</TextBlock>
				<local:TilePanel Margin="0,16,0,0"></local:TilePanel>
			</StackPanel>
			<Line Margin="0,25,0,15" X1="0" Y1="0" X2="400" Y2="0" Style="{DynamicResource TilePowerFlyoutSpillter}"></Line>
			<StackPanel>
				<TextBlock Name="TitlePrds" Style="{DynamicResource TilePowerFlyoutTitle1}">Power-Related Display Settings</TextBlock>
				<TextBlock Name="TitleKeepScreen" Style="{DynamicResource TilePowerFlyoutTitle2}">Keep my screen on</TextBlock>
				<TextBlock Name="DescKeepScreen" Margin="0,2,0,2">To conserve ...</TextBlock>
				<CheckBox Name="InputKeepScreen" Margin="0,2,0,2">Keep my screen on for the rest of this Windows session</CheckBox>
				<TextBlock Name="TitleAsb" Style="{DynamicResource TilePowerFlyoutTitle2}">Adjust the screen brightness</TextBlock>
				<TextBlock Name="DescAsb" Margin="0,2,0,2">You can conserve ...</TextBlock>
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Name="TipDim">Dim</TextBlock>
					<Slider Name="InputBrightness" AutoToolTipPlacement="TopLeft" AutoToolTipPrecision="0" Minimum="0" Maximum="100" TickFrequency="1"  Width="300" Margin="10,0,10,0"></Slider>
					<TextBlock Name="TipBright">Bright</TextBlock>
					<TextBlock Name="LabelBrightnessTip" Margin="20,0,0,0">
						<Run Name="LabelBrightnessTipPercent" Text="{Binding ElementName=InputBrightness, Path=Value, StringFormat={}{0:F0}}" />
						<Run Text="%" />
					</TextBlock>
				</StackPanel>
			</StackPanel>
			<Line Margin="0,15,0,5" X1="0" Y1="0" X2="400" Y2="0" StrokeThickness="2" Style="{DynamicResource TilePowerFlyoutSpillter}"></Line>
			<StackPanel Margin="0,5,0,5" Orientation="Horizontal" VerticalAlignment="Center">
				<ToggleButton Name="FoldButton" Width="17" Height="17" Style="{DynamicResource TilePowerFoldToggleButton}" Checked="FoldButton_Checked" Unchecked="FoldButton_Unchecked"></ToggleButton>
				<TextBlock Margin="8,0,0,0" Name="LabelFold">Show power plans</TextBlock>
			</StackPanel>
			<StackPanel Name="PowerPlansPart">
				<DockPanel LastChildFill="False">
					<Image Width="75" Name="ImagePowerPlan" DockPanel.Dock="Right"></Image>
					<TextBlock Name="TitlePowerPlans" Style="{DynamicResource TilePowerFlyoutTitle1}">Power Plans</TextBlock>
				</DockPanel>
				<RadioButton Name="InputPlanLongest" Margin="0,2,0,2">
					<TextBlock>
						<Run Name="TitleLongest" Text="Longest Battery Life" />
						<LineBreak />
						<Run Name="DescLongest" Text="Barrery power is more important than computer speed." />
					</TextBlock>
				</RadioButton>
				<RadioButton Name="InputPlanBalanced" Margin="0,2,0,2">
					<TextBlock>
						<Run Name="TitleBalanced" Text="Balanced (Recommended)" />
						<LineBreak />
						<Run Name="DescBalanced" Text="Barrery power is more important than computer speed." />
					</TextBlock>
				</RadioButton>
				<RadioButton Name="InputPlanHighest" Margin="0,2,0,2">
					<TextBlock>
						<Run Name="TitleHighest" Text="Highest Performance" />
						<LineBreak />
						<Run Name="DescHighest" Text="Barrery power is more important than computer speed." />
					</TextBlock>
				</RadioButton>
			</StackPanel>
		</StackPanel>
    </Grid>
</UserControl>
