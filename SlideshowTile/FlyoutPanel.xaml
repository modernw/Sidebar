<UserControl x:Class="WindowsModern.SlideshowTile.FlyoutPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.SlideshowTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<DockPanel>
			<TextBlock Name="FileName" DockPanel.Dock="Top" TextTrimming="CharacterEllipsis" Style="{DynamicResource TileSlideshowFlyoutFileName}"></TextBlock>
			<StackPanel MinHeight="27" Margin="0,3,0,3" DockPanel.Dock="Bottom" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
				<Button Name="BtnBack" Click="BtnBack_Click" Style="{DynamicResource TileSlideshowBackButton}"></Button>
				<Button Name="BtnNext" Click="BtnNext_Click" Margin="10,0,10,0" Style="{DynamicResource TileSlideshowNextButton}"></Button>
				<Button Name="BtnOpenFile" Click="BtnOpenFile_Click" Style="{DynamicResource TileSlideshowOpenFileButton}"></Button>
			</StackPanel>
			<Viewbox>
				<Image Name="Image"></Image>
			</Viewbox>
		</DockPanel>
    </Grid>
</UserControl>
