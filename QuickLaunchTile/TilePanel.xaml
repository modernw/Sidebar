<UserControl x:Class="WindowsModern.QuickLaunchTile.TilePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.QuickLaunchTile"
             mc:Ignorable="d" Loaded="UserControl_Loaded"
             d:DesignHeight="300" d:DesignWidth="300">

	<UserControl.Resources>
		<DataTemplate x:Key="ItemTemplate">
			<ToggleButton Style="{DynamicResource TileIconItemForQuickLaunchTile}"
                          ToolTip="{Binding Description}"
                          Command="{Binding LeftClickCommand}"
                          Tag="{Binding}"
                          MouseDoubleClick="ToggleButton_MouseDoubleClick">
				<Image Source="{Binding IconSource}" Width="16" Height="16"/>
			</ToggleButton>
		</DataTemplate>
	</UserControl.Resources>

	<Grid Height="Auto">
		<ItemsControl Style="{DynamicResource TileIconItemTileContainerForQuickLaunchTile}"
                      Name="ItemContainer"
                      ItemsSource="{Binding TrayIcons}"
                      ItemTemplate="{DynamicResource ItemTemplate}"
                      ItemsPanel="{DynamicResource TileIconItemWrapPanelForQuickLaunchTile}"
                      PreviewMouseRightButtonDown="ItemContainer_PreviewMouseRightButtonDown"/>
	</Grid>
</UserControl>