<UserControl x:Class="WindowsModern.QuickLaunchTile.OptionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.QuickLaunchTile"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
		<StackPanel Margin="10,10,10,10">
			<TextBlock Margin="0,0,0,20">No items to configure.</TextBlock>
			<TextBlock Margin="0,0,0,5">Current Quick Launch Folder: </TextBlock>
			<TextBox Padding="3,3,3,3" Name="FolderName" IsReadOnly="True"></TextBox>
		</StackPanel>
    </Grid>
</UserControl>
