<UserControl x:Class="WindowsModern.QuickLaunchTile.FlyoutPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WindowsModern.QuickLaunchTile"
             mc:Ignorable="d" Loaded="UserControl_Loaded" SizeChanged="UserControl_SizeChanged"
             d:DesignHeight="300" d:DesignWidth="300">
	<UserControl.Resources>
		<DataTemplate x:Key="ItemTemplate">
			<ToggleButton Style="{DynamicResource TileIconItemWithTextForQuickLaunchTile}"
                          ToolTip="{Binding Description}"
                          Command="{Binding LeftClickCommand}"
                          Tag="{Binding}"
                          MouseDoubleClick="ToggleButton_MouseDoubleClick">
				<StackPanel Margin="4,4,4,4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Stretch">
					<Image Source="{Binding IconSource}" Width="16" Height="16" Stretch="Uniform"/>
					<TextBlock Text="{Binding Title}" Style="{DynamicResource TileIconItemWithTextItemTextPart}"/>
				</StackPanel>
			</ToggleButton>
		</DataTemplate>
	</UserControl.Resources>
	<Grid Width="Auto" Height="Auto" MaxHeight="400" MaxWidth="500">
		<ScrollViewer VerticalScrollBarVisibility="Auto" Style="{DynamicResource AutoHideScrollViewer}">
			<ItemsControl
                      Name="ItemContainer"
                      ItemsSource="{Binding TrayIcons}"
                      ItemTemplate="{DynamicResource ItemTemplate}"
                      ItemsPanel="{DynamicResource TileIconItemWithTextWrapPanel}"
                      PreviewMouseRightButtonDown="ItemContainer_PreviewMouseRightButtonDown"/>
		</ScrollViewer>
	</Grid>
</UserControl>